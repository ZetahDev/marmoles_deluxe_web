---
import { buildCloudinaryImageSet, CLOUDINARY_PRESETS } from "../lib/images/cloudinary";
import { getBrandLogo } from "../lib/images/cloudinaryAssets";

const logos = [
  { name: "Altea", url: getBrandLogo("Altea") },
  { name: "Catemar", url: getBrandLogo("catemar") },
  { name: "Dekton", url: getBrandLogo("dekton") },
  { name: "Neolith", url: getBrandLogo("neolith") },
  { name: "Sensa", url: getBrandLogo("Sensa") },
  { name: "Silestone", url: getBrandLogo("silestone") },
].map((logo) => ({
  ...logo,
  image: buildCloudinaryImageSet(logo.url, CLOUDINARY_PRESETS.logo),
}));

// Duplicamos el array para crear un desplazamiento continuo
const allLogos = [...logos, ...logos];
---

<section class="bg-marmoles-black py-2 overflow-hidden">
  <div class="logos-container">
    <div class="logos-slide">
      {
        allLogos.map((logo) => (
          <div class="logo-item">
            <img
              src={logo.image.src}
              srcset={logo.image.srcSet}
              sizes={logo.image.sizes}
              alt={`Logo de ${logo.name}`}
              class="h-10 w-auto object-contain filter brightness-0 invert opacity-80 hover:opacity-100 transition-opacity duration-300"
              width="120"
              height="40"
              loading="lazy"
              decoding="async"
            />
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .logos-container {
    width: 100%;
    overflow: hidden;
    position: relative;
    padding: 1rem 0;
  }

  .logos-slide {
    display: flex;
    gap: 3rem;
    animation: slide 30s linear infinite;
    width: max-content;
  }

  .logo-item {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @keyframes slide {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  /* Pausa la animación al hacer hover */
  .logos-container:hover .logos-slide {
    animation-play-state: paused;
  }
</style>
