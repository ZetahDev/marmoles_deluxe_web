---
import { cloudinaryAssets } from "../lib/images/cloudinaryAssets";
import {
  buildCloudinaryImageSet,
  CLOUDINARY_PRESETS,
} from "../lib/images/cloudinary";

const navItems = [
  {
    href: "/",
    label: "Logo",
    isLogo: true,
  },
  {
    href: "/",
    label: "Inicio",
  },
  {
    label: "Materiales",
    items: [
      { href: "/piedra-sinterizada", label: "Piedra Sinterizada" },
      { href: "/quartzstone", label: "Quartzstone" },
      { href: "/marmoles", label: "Mármoles" },
      { href: "/granitos-naturales", label: "Granito" },
      { href: "/piedra-exotica", label: "Piedra Exótica" },
    ],
  },
  //{ href: "/productos", label: "Productos" },
  { href: "/nosotros", label: "Nosotros" },
  { href: "/otros-servicios", label: "Otros Servicios" },
  { href: "/b2b", label: "B2B" },
  { href: "/proyectos", label: "Proyectos" },
  { href: "/casos-de-estudio", label: "Casos" },
  { href: "/politicas-garantia", label: "Garantías" },
  { href: "/contactanos", label: "Contáctanos" },
];

const currentPath = Astro.url.pathname;
const logoImage = buildCloudinaryImageSet(
  cloudinaryAssets.branding.logoMain,
  CLOUDINARY_PRESETS.logo
);

// Helper para verificar si la ruta actual está bajo Materiales
const isCurrentPathUnderMateriales = () => {
  const materialesItems =
    navItems.find((item) => item.label === "Materiales")?.items || [];
  return materialesItems.some((item) => currentPath.startsWith(item.href));
};
---

<header
  class="fixed w-full top-0 left-0 z-50 backdrop-blur-md border-b border-white/20"
>
  <nav class="container mx-auto px-4">
    <div class="flex items-center justify-center h-16">
      <!-- Menú móvil nativo (sin hidratación React) -->
      <div class="md:hidden absolute left-4">
        <input id="mobile-nav-toggle" type="checkbox" class="peer sr-only" />
        <label
          for="mobile-nav-toggle"
          class="inline-flex items-center justify-center p-2 text-marmoles-gold hover:text-marmoles-gold transition-colors cursor-pointer"
          aria-label="Menú"
        >
          <svg
            class="h-6 w-6"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"
            />
          </svg>
        </label>

        <label
          for="mobile-nav-toggle"
          class="fixed inset-0 top-16 z-40 bg-black/60 hidden peer-checked:block"
          aria-label="Cerrar menú"
        ></label>

        <div class="fixed top-16 left-0 z-50 w-full max-h-0 overflow-hidden bg-white/80 border-b border-white/20 shadow-2xl transition-all duration-300 peer-checked:max-h-screen">
          <div class="px-4 py-3 space-y-3">
            {
              navItems.map((item) => {
                if (item.isLogo) return null;
                if (item.label === "Inicio") {
                  return (
                    <a
                      href={item.href}
                      class:list={[
                        "block text-sm font-medium py-2 transition-colors",
                        {
                          "text-marmoles-gold":
                            currentPath === item.href ||
                            currentPath.endsWith(item.href),
                          "text-gray-800 hover:text-marmoles-gold": !(
                            currentPath === item.href ||
                            currentPath.endsWith(item.href)
                          ),
                        },
                      ]}
                    >
                      {item.label}
                    </a>
                  );
                }

                if (item.items) {
                  return (
                    <details class="group" open={isCurrentPathUnderMateriales()}>
                      <summary class="list-none text-sm font-medium text-gray-800 hover:text-marmoles-gold w-full py-2 flex justify-between items-center cursor-pointer">
                        <span>{item.label}</span>
                        <span class="transition-transform group-open:rotate-180">
                          <svg
                            class="h-4 w-4"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              stroke-width="2"
                              d="M19 9l-7 7-7-7"
                            />
                          </svg>
                        </span>
                      </summary>
                      <div class="pl-4 space-y-2 pb-1">
                        {item.items.map((subItem) => (
                          <a
                            href={subItem.href}
                            class:list={[
                              "block text-sm font-medium py-2 transition-colors",
                              {
                                "text-marmoles-gold":
                                  currentPath === subItem.href ||
                                  currentPath.endsWith(subItem.href),
                                "text-gray-800 hover:text-marmoles-gold": !(
                                  currentPath === subItem.href ||
                                  currentPath.endsWith(subItem.href)
                                ),
                              },
                            ]}
                          >
                            {subItem.label}
                          </a>
                        ))}
                      </div>
                    </details>
                  );
                }

                return (
                  <a
                    href={item.href}
                    class:list={[
                      "block text-sm font-medium py-2 transition-colors",
                      {
                        "text-marmoles-gold":
                          currentPath === item.href ||
                          currentPath.endsWith(item.href),
                        "text-gray-800 hover:text-marmoles-gold": !(
                          currentPath === item.href ||
                          currentPath.endsWith(item.href)
                        ),
                      },
                    ]}
                  >
                    {item.label}
                  </a>
                );
              })
            }
          </div>
        </div>
      </div>

      <!-- Menú para escritorio -->
      <div class="hidden md:flex items-center justify-center space-x-8">
        {
          navItems.map((item) => {
            if (item.isLogo) {
              return (
                <a href={item.href} class="mx-4">
                  <img
                    src={logoImage.src}
                    srcset={logoImage.srcSet}
                    sizes={logoImage.sizes}
                    alt="Mármoles Deluxe Logo"
                    class="h-12 w-auto logo-gold"
                    width="180"
                    height="48"
                    decoding="async"
                    fetchpriority="high"
                  />
                </a>
              );
            }
            if (item.label === "Inicio") {
              return null; // No mostrar Inicio en desktop, el logo ya lleva a /
            }
            if (item.items) {
              return (
                <div class="relative group">
                  <button
                    class:list={[
                      "text-sm font-medium transition-colors relative group px-2 py-1",
                      {
                        "text-marmoles-gold": isCurrentPathUnderMateriales(),
                        "text-marmoles-gold/95":
                          !isCurrentPathUnderMateriales(),
                      },
                    ]}
                  >
                    {item.label}
                    <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-marmoles-gold transition-all duration-300 group-hover:w-full" />
                  </button>
                  <div class="absolute hidden group-hover:block w-48 bg-white/80 backdrop-blur-md border border-white/20 rounded-md shadow-lg py-2 mt-2">
                    <div class="absolute -top-2 left-0 right-0 h-4 bg-transparent" />
                    {item.items.map(({ href, label }) => (
                      <a
                        href={href}
                        class="block px-4 py-2 text-sm text-gray-800 hover:text-marmoles-gold hover:bg-white/20"
                      >
                        {label}
                      </a>
                    ))}
                  </div>
                </div>
              );
            }
            return (
              <a
                href={item.href}
                class:list={[
                  "text-sm font-medium transition-colors hover:text-marmoles-gold relative group",
                  {
                    "text-marmoles-gold":
                      currentPath === item.href ||
                      currentPath.endsWith(item.href),
                    "text-marmoles-gold/95": !(
                      currentPath === item.href ||
                      currentPath.endsWith(item.href)
                    ),
                  },
                ]}
              >
                {item.label}
                <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-marmoles-gold transition-all duration-300 group-hover:w-full" />
              </a>
            );
          })
        }
      </div>
    </div>
  </nav>
</header>

<style>
  .backdrop-blur-md {
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }

  @media (max-width: 767px) {
    .backdrop-blur-md {
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
    }
  }

  .logo-gold {
    filter: brightness(0) saturate(100%) invert(80%) sepia(38%) saturate(636%)
      hue-rotate(358deg) brightness(90%) contrast(85%);
  }
</style>
