---
import type { GeoFaqItem } from "../lib/business";

interface Props {
  title: string;
  intro: string;
  faqs: GeoFaqItem[];
}

const { title, intro, faqs } = Astro.props;
---

<section class="py-16 bg-white">
  <div class="container mx-auto px-4 sm:px-6 max-w-5xl">
    <div class="text-center mb-10">
      <h2 class="text-3xl md:text-4xl font-bold text-marmoles-black mb-4">
        {title}
      </h2>
      <p class="text-lg text-gray-600 max-w-3xl mx-auto">{intro}</p>
    </div>

    <div class="space-y-4">
      {
        faqs.map((faq) => (
          <article class="rounded-2xl border border-gray-200 bg-gray-50 p-6 shadow-sm">
            <h3 class="text-xl font-semibold text-marmoles-black mb-3">
              {faq.question}
            </h3>
            <p class="text-gray-700 leading-relaxed">{faq.answer}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
