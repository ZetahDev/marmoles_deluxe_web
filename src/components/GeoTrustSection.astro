---
interface Props {
  title: string;
  answer: string;
  bullets: string[];
}

const { title, answer, bullets } = Astro.props;
---

<section class="py-16 bg-gradient-to-b from-gray-50 to-white">
  <div class="container mx-auto px-4 sm:px-6 max-w-6xl">
    <div class="rounded-3xl border border-marmoles-gold/20 bg-white p-8 shadow-lg">
      <div class="max-w-3xl mb-8">
        <span class="inline-flex rounded-full bg-marmoles-gold/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-marmoles-gold">
          Señales de confianza
        </span>
        <h2 class="mt-4 text-3xl md:text-4xl font-bold text-marmoles-black">
          {title}
        </h2>
        <p class="mt-4 text-lg leading-relaxed text-gray-700">{answer}</p>
      </div>

      <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
        {
          bullets.map((bullet) => (
            <div class="rounded-2xl bg-gray-50 p-5 text-gray-700 shadow-sm">
              <p class="font-medium">{bullet}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
