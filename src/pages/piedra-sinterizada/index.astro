---
import Layout from "../../layouts/Layout.astro";
import CategoryFilter from "../../components/CategoryFilter.tsx";
import CategoryWrapper from "../../components/CategoryWrapper.tsx";
import SEOSchemaData from "../../components/SEOSchemaData.tsx";
import GeoBusinessSchema from "../../components/GeoBusinessSchema.astro";
import GeoFaqSection from "../../components/GeoFaqSection.astro";
import GeoTrustSection from "../../components/GeoTrustSection.astro";
import { listProviderGroupsFromCatalog } from "../../lib/utils/s3Utils";
import { slugify } from "../../lib/utils";
import { cloudinaryAssets } from "../../lib/images/cloudinaryAssets";
import { buildSeoImageUrl } from "../../lib/images/cloudinary";
import cloudinaryIndex from "../../data/cloudinary-index.json";

// Define stone type features
interface StoneTypeFeatures {
  [key: string]: string[];
}

// Configuración: usar anclas (#neolith) en lugar de parámetros (?categoria=neolith)
const useAnchorLinks = true;

// Generate category descriptions for SEO (optimizado para búsquedas en Google)
const categoryDescriptions = {
  Altea:
    "Piedra sinterizada Altea en Cali | Material premium para encimeras de cocina y baños con 10 años de garantía. Resistencia superior a químicos, manchas y altas temperaturas. Distribuidor autorizado en Valle del Cauca | Instalación profesional | Precio competitivo.",
  Dekton:
    "Dekton piedra sinterizada Cali | Superficie ultracompacta para cocinas, baños y fachadas. 25 años de garantía, resistencia total a rayones, manchas y calor. Distribuidor oficial Valle del Cauca | Instalación experta | Cotización gratis.",
  Neolith:
    "Neolith encimeras de cocina Cali | Piedra sinterizada de lujo con 25 años de garantía. Resistente a rayones, manchas, UV y calor extremo. Ideal para cocinas modernas, baños y exteriores | Distribuidor autorizado Cali | Mejor precio.",
  Silestone:
    "Silestone cuarzo Cali | Superficies de cuarzo para cocinas y baños con tecnología antibacteriana. 25 años de garantía, variedad de colores y diseños. Distribuidor oficial Valle del Cauca | Instalación certificada | Financiación disponible.",
  Artemarmol:
    "Artemarmol piedra sinterizada Cali | Diseños exclusivos y sofisticados con tecnología de última generación. Alta resistencia y formatos grandes para superficies continuas. Distribuidor oficial.",
  Terracina:
    "Terracina piedra sinterizada Cali | Superficies premium de gran formato para cocinas, baños y aplicaciones de alto nivel. Asesoría e instalación profesional en Cali y Valle del Cauca.",
};

const features: StoneTypeFeatures = {
  Neolith: [
    "🏆 Piedra sinterizada de lujo",
    "🔥 Resistencia extrema al calor",
    "💎 Dureza superior tipo diamante",
    "💧 Completamente impermeable",
    "🍴 Apta para preparación de alimentos",
    "☀️ Resistente a rayos UV para exteriores",
    "🧪 Resistente a químicos y ácidos",
    "⭐ 25 años de garantía",
    "🎨 Diseños exclusivos y elegantes",
    "♻️ 100% reciclable",
  ],
  Altea: [
    "✨ Superficie ultracompacta de alta resistencia",
    "🔥 Soporta altas temperaturas hasta 300°C",
    "💎 Resistente a químicos, ácidos y solventes domésticos",
    "🛡️ Resistencia superior a rayones y abrasión",
    "💧 Absorción casi nula de líquidos (0.02%)",
    "🍳 Certificada para contacto directo con alimentos",
    "🏠 Perfecta para interiores y exteriores",
    "⭐ 10 años de garantía del fabricante",
    "🌈 Amplia variedad de colores y acabados",
    "♻️ Material ecológico y reciclable",
  ],
  Dekton: [
    "💪 Ultracompacto de máxima resistencia",
    "🔥 Resistente a temperaturas extremas",
    "🛡️ Resistencia total a rayones y abrasión",
    "💧 Absorción cero de líquidos",
    "🍽️ Higiénico para contacto con alimentos",
    "☀️ Resistente a rayos UV (no se decolora)",
    "🏡 Ideal para cocinas, baños y exteriores",
    "⭐ 25 años de garantía Cosentino",
    "🎨 Múltiples diseños y texturas",
    "🌍 Material sostenible",
  ],
  Silestone: [
    "🦠 Tecnología antibacteriana Microban®",
    "💎 Cuarzo natural de alta calidad",
    "🔥 Resistente al calor y manchas",
    "🛡️ Superficie no porosa",
    "🍳 Higiénica para cocinas",
    "🎨 +90 colores disponibles",
    "⭐ 25 años de garantía",
    "🧽 Fácil limpieza y mantenimiento",
    "💪 Alta resistencia al uso diario",
    "🏠 Ideal para cocinas y baños",
  ],
  Artemarmol: [
    "✨ Diseños de vanguardia de alta definición",
    "🔥 Resistente al calor y al fuego",
    "💎 Superficie ultracompacta resistente a rayones",
    "💧 Impermeable y fácil de limpiar",
    "🍳 Apto para contacto con alimentos",
    "☀️ Resistente a rayos UV para exteriores",
    "🦶 Alto tránsito y resistencia a la abrasión",
    "🏠 Formatos grandes para menos juntas",
    "⭐ Calidad premium garantizada",
    "♻️ Sostenible y eco-amigable",
  ],
  Terracina: [
    "✨ Diseños de lectura premium y contemporánea",
    "🔥 Alta resistencia al calor para superficies exigentes",
    "💎 Superficie compacta de buena respuesta al uso diario",
    "💧 Baja absorción y limpieza práctica",
    "🏠 Aplicable a cocinas, baños y proyectos arquitectónicos",
    "📐 Gran formato para composiciones más continuas",
  ],
};

const providerOrder = [
  "Terracina",
  "Artemarmol",
  "Altea",
  "Dekton",
  "Silestone",
  "Neolith",
];

const providerAllowlist = new Set(providerOrder.map((provider) => provider.toLowerCase()));

function toCanonicalProviderName(raw: string) {
  const normalized = raw.trim().toLowerCase();
  if (normalized === "arte mármol" || normalized === "arte marmol") return "Artemarmol";
  if (normalized === "artemarmol") return "Artemarmol";
  if (normalized === "altea") return "Altea";
  if (normalized === "dekton") return "Dekton";
  if (normalized === "silestone") return "Silestone";
  if (normalized === "neolith") return "Neolith";
  if (normalized === "terracina") return "Terracina";
  return raw.trim();
}

// Precios por marca (solo Altea tiene calculadora habilitada)
const preciosPorMarca: Record<
  string,
  { precioPublico: number; unidad: string } | null
> = {
  Altea: {
    precioPublico: 960000,
    unidad: "m lineal",
  },
  Dekton: null, // Sin calculadora
  Neolith: null, // Sin calculadora
  Silestone: null, // Sin calculadora
  Artemarmol: null, // Sin calculadora
  "Arte Mármol": null,
  Terracina: null,
};

const providerGroups = await listProviderGroupsFromCatalog("Piedra sinterizada");
const fallbackCategories = (cloudinaryIndex as any)?.categories ?? {};
const fallbackGroups = Object.entries(fallbackCategories)
  .filter(([key]) => key.startsWith("PIEDRA+SINTERIZADA/"))
  .map(([key, stones]) => {
    const providerFromKey = toCanonicalProviderName((key.split("/").pop() ?? "").trim());
    return {
      provider: providerFromKey,
      slug: slugify(providerFromKey),
      stones: (stones as any[]).map((stone) => ({
        name: stone.name ?? "",
        image: stone.image ?? "",
        design: stone.design ?? stone.image ?? "",
      })),
    };
  })
  .filter((group) => providerAllowlist.has(group.provider.toLowerCase()) && group.stones.length > 0);

const providerByCanonicalName = new Map<string, (typeof providerGroups)[number]>();
for (const group of providerGroups) {
  const canonical = toCanonicalProviderName(group.provider);
  if (!providerAllowlist.has(canonical.toLowerCase())) continue;
  const previous = providerByCanonicalName.get(canonical);
  if (!previous || group.stones.length > previous.stones.length) {
    providerByCanonicalName.set(canonical, {
      ...group,
      provider: canonical,
      slug: slugify(canonical),
    });
  }
}
for (const group of fallbackGroups) {
  if (!providerByCanonicalName.has(group.provider)) {
    providerByCanonicalName.set(group.provider, group);
  }
}
const mergedProviderGroups = providerOrder
  .map((provider) => providerByCanonicalName.get(provider))
  .filter(Boolean) as typeof providerGroups;
const providerRank = new Map(
  providerOrder.map((provider, index) => [slugify(provider), index])
);

const stoneCategories = mergedProviderGroups
  .map((group) => {
    const precios = preciosPorMarca[group.provider];

    return {
      title: group.provider,
      stones: group.stones,
      features: features[group.provider],
      precioPublico: precios?.precioPublico || undefined,
      unidad: precios?.unidad || undefined,
    };
  })
  .sort((left, right) => {
    const leftRank = providerRank.get(slugify(left.title)) ?? Number.MAX_SAFE_INTEGER;
    const rightRank = providerRank.get(slugify(right.title)) ?? Number.MAX_SAFE_INTEGER;
    if (leftRank !== rightRank) return leftRank - rightRank;
    return left.title.localeCompare(right.title, "es");
  });

const providerNames = stoneCategories.map((category) => category.title);
const providerListText = providerNames.join(", ");

console.log("[piedra-sinterizada] server_render:data", {
  providerGroups: mergedProviderGroups.map((group) => ({
    provider: group.provider,
    slug: group.slug,
    stones: group.stones.length,
  })),
  stoneCategories: stoneCategories.map((category) => ({
    title: category.title,
    stones: category.stones.length,
    hasFeatures: Boolean(category.features?.length),
  })),
  providerNames,
});

// Get the category from URL for server-side rendering of metadata
const { url } = Astro;
const params = url.searchParams;
const categoryParam = params.get("categoria")?.toLowerCase();
// Los fragmentos (#) no forman parte de la URL indexable y no deben
// alterar metadata ni canonical.
const effectiveCategory = categoryParam;

// Default metadata - Optimizado para SEO con enfoque en Altea
let title = "Piedra Sinterizada Altea, Dekton y Neolith Cali | Mármoles Deluxe";
let description =
  `Distribuidor de piedra sinterizada en Cali: ${providerListText}. Encimeras de cocina, baños y superficies premium con instalación profesional en Valle del Cauca. ¡Cotización gratis!`;
let keywords =
  `piedra sinterizada cali, ${providerNames.map((provider) => `${provider.toLowerCase()} cali`).join(", ")}, encimeras cocina cali, encimeras baño cali, superficies cocina, resistente calor, ultracompacto`;

// Prepare data for schema.org
let schemaCategory: string | undefined;
let schemaStones: Array<{ name: string; image: string }> = [];

// Update metadata if a valid category is specified
if (effectiveCategory) {
  const formattedCategory =
    stoneCategories.find((category) => slugify(category.title) === effectiveCategory)
      ?.title ?? null;

  if (formattedCategory) {
    title = `${formattedCategory} - Piedra Sinterizada | Mármoles Deluxe`;
    description =
      categoryDescriptions[formattedCategory] ??
      `Piedra sinterizada ${formattedCategory} en Cali | Superficies premium para cocinas, baños y proyectos arquitectónicos con asesoría e instalación profesional.`;

    // Set schema.org data for this category
    schemaCategory = formattedCategory;
    const categoryData = stoneCategories.find(
      (cat) => cat.title === formattedCategory
    );
    if (categoryData) {
      schemaStones = categoryData.stones.map((stone) => ({
        name: stone.name,
        image: stone.image,
      }));
    }
  }
}

// Canonical URL (important for SEO)
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
if (!useAnchorLinks && categoryParam) {
  // Si usamos parámetros, incluirlos en el canonical
  canonicalURL.searchParams.set("categoria", categoryParam);
}

// Default image for SEO
const image = buildSeoImageUrl(cloudinaryAssets.seo.piedraSinterizada);
const sinterizadaFaqs = [
  {
    question: "¿Qué ventajas tiene la piedra sinterizada frente a otras superficies?",
    answer:
      "La piedra sinterizada destaca por su resistencia al calor, baja absorción, estabilidad del color y buen desempeño en cocinas, baños y algunas aplicaciones exteriores. La marca y el espesor adecuados dependen del uso final del proyecto.",
  },
  {
    question: "¿Qué marcas de piedra sinterizada ofrece Mármoles Deluxe en Cali?",
    answer:
      `Trabajamos líneas como ${providerListText}, cada una con formatos, diseños, garantías y atributos técnicos distintos según la aplicación.`,
  },
  {
    question: "¿La piedra sinterizada sirve para cocinas y fachadas?",
    answer:
      "Sí, pero no todas las referencias se recomiendan igual para cada uso. La selección correcta depende de exposición solar, tránsito, formato, soporte y exigencia mecánica del proyecto.",
  },
];
---

<Layout
  title={title}
  description={description}
  enableSpeedInsights={false}
>
  <Fragment slot="head">
    <!-- SEO Meta Tags -->
    <meta name="keywords" content={keywords} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Mármoles Deluxe" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:locale" content="es_CO" />
    <meta property="og:site_name" content="Mármoles Deluxe" />

    <!-- Twitter Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Geo Tags -->
    <meta name="geo.region" content="CO-VAC" />
    <meta name="geo.placename" content="Cali" />
    <meta name="geo.position" content="3.4516;-76.5320" />
    <meta name="ICBM" content="3.4516, -76.5320" />
  </Fragment>

  <!-- Add Schema.org structured data for SEO -->
  <SEOSchemaData
    pageTitle={title}
    pageDescription={description}
    pageUrl={Astro.url.href}
    pageImage={image}
    category={schemaCategory}
    stones={schemaStones}
  />
  <GeoBusinessSchema
    pageTitle={title}
    pageDescription={description}
    pageUrl={canonicalURL.toString()}
    pageImage={image}
    pageType="CollectionPage"
    faqs={sinterizadaFaqs}
  />

  <CategoryFilter client:idle categories={providerNames} />

  <!-- Hero Section optimizado para SEO -->
  <section
    class="relative py-16 bg-gradient-to-br from-marmoles-black to-gray-900 text-white"
  >
    <div class="container mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-6xl font-bold mb-4">
        Piedra Sinterizada <span class="text-marmoles-gold">Premium</span>
      </h1>
      <p class="text-xl md:text-2xl mb-6 text-gray-200">
        Distribuidor Oficial en Cali y Valle del Cauca
      </p>
      <p class="text-lg mb-8 max-w-3xl mx-auto">
        Especialistas en piedra sinterizada para cocinas, baños y superficies de
        alta resistencia. Trabajamos líneas como <strong>{providerListText}</strong>
        con asesoría comercial e instalación profesional en Cali.
      </p>
      <div class="flex flex-wrap justify-center gap-4 mb-8">
        {
          providerNames.map((provider, index) => (
            <a
              href={`#${slugify(provider)}`}
              class={`px-8 py-3 rounded-lg font-semibold hover:bg-opacity-90 transition-all ${
                index === 0
                  ? "bg-marmoles-gold text-marmoles-black"
                  : "bg-white text-marmoles-black"
              }`}
            >
              {provider}
            </a>
          ))
        }
      </div>
      <div class="flex flex-wrap justify-center gap-3 mb-6">
        {
          providerNames.map((provider) => (
            <a
              href={`/piedra-sinterizada/${slugify(provider)}`}
              class="px-4 py-2 rounded-md border border-white/30 text-sm font-semibold text-white hover:bg-white/10 transition"
            >
              Ver página {provider}
            </a>
          ))
        }
      </div>
      <p class="text-sm text-gray-300">
        ✓ Instalación Profesional | ✓ Garantía Extendida | ✓ Cotización Gratuita
      </p>
    </div>
  </section>

  <main class="py-20">
    <div class="container mx-auto px-4">
      <!-- Sección de ventajas -->
      <div class="mb-16 text-center">
        <h2 class="text-3xl font-bold mb-8">
          ¿Por qué elegir piedra sinterizada?
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
          <div class="p-6 bg-white rounded-lg shadow-md">
            <div class="text-4xl mb-3">🔥</div>
            <h3 class="font-bold mb-2">Resistencia al Calor</h3>
            <p class="text-sm text-gray-600">Soporta hasta 300°C sin daños</p>
          </div>
          <div class="p-6 bg-white rounded-lg shadow-md">
            <div class="text-4xl mb-3">💎</div>
            <h3 class="font-bold mb-2">Anti-Rayones</h3>
            <p class="text-sm text-gray-600">Máxima dureza y resistencia</p>
          </div>
          <div class="p-6 bg-white rounded-lg shadow-md">
            <div class="text-4xl mb-3">💧</div>
            <h3 class="font-bold mb-2">Impermeabilidad</h3>
            <p class="text-sm text-gray-600">Absorción casi nula de líquidos</p>
          </div>
          <div class="p-6 bg-white rounded-lg shadow-md">
            <div class="text-4xl mb-3">⭐</div>
            <h3 class="font-bold mb-2">Garantía</h3>
            <p class="text-sm text-gray-600">Hasta 25 años de garantía</p>
          </div>
        </div>
      </div>

      <CategoryWrapper
        client:idle
        categories={stoneCategories}
        useAnchorLinks={useAnchorLinks}
      />

      <script
        is:inline
        define:vars={{
          categoryDebug: stoneCategories.map((category) => ({
            title: category.title,
            stones: category.stones.length,
          })),
        }}
      >
        console.log("[piedra-sinterizada] client_bootstrap:categories", categoryDebug);
      </script>

      <div class="mt-16 space-y-16">
        <GeoTrustSection
          title="Cómo evaluamos piedra sinterizada para proyectos reales"
          answer="La elección de una superficie sinterizada no se reduce al color. En la práctica importan el uso, el formato, el espesor, la exposición al calor, la logística de instalación y el comportamiento esperado a largo plazo. Esa experiencia aplicada es la que intentamos reflejar en esta página."
          bullets={[
            "Comparación de varias marcas con descripciones y beneficios diferenciados.",
            "Señales técnicas visibles: calor, rayones, impermeabilidad, UV y garantía.",
            "Orientación local para proyectos en Cali con instalación y asesoría comercial.",
          ]}
        />

        <GeoFaqSection
          title="Preguntas frecuentes sobre piedra sinterizada en Cali"
          intro="Estas respuestas están redactadas para resolver dudas de compra y para reforzar la autoridad temática de la página sobre superficies sinterizadas."
          faqs={sinterizadaFaqs}
        />
      </div>
    </div>
  </main>
</Layout>

<script>
  import { initModal } from "../../scripts/modal";
  initModal();
</script>
