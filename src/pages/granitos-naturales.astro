---
import Layout from "../layouts/Layout.astro";
import ProductCard from "../components/ProductCard.tsx";
import SEOSchemaData from "../components/SEOSchemaData.tsx";
import { listStonesFromS3, type Stone } from "../lib/utils/s3Utils";
import { cloudinaryAssets } from "../lib/images/cloudinaryAssets";
import { buildSeoImageUrl, buildCloudinaryImageSet, CLOUDINARY_PRESETS } from "../lib/images/cloudinary";

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const pageUrl = canonicalURL.toString();
const heroImageUrl = cloudinaryAssets.home.projectBlackDiamond;
const heroImage = buildCloudinaryImageSet(heroImageUrl, CLOUDINARY_PRESETS.hero);
const metaImage = buildSeoImageUrl(heroImageUrl);
const title = "Granitos Naturales Cali - Mármoles Deluxe | Encimeras Durables";
const description =
  "Explora nuestra colección de granitos naturales de alta calidad para encimeras, pisos y superficies. Material elegante y duradero para tu hogar u oficina.";

const keywords =
  "granitos naturales Cali, granito negro, granito blanco, encimeras granito Cali, pisos granito, granito cocina, granito baño, granito brasileño, instalación granito Valle del Cauca";

// Fetch granite data at build time
const granitosNaturales = await listStonesFromS3("GRANITOS+NATURALES");

// Configurar datos para schema.org
const schemaStones = granitosNaturales.map((stone: Stone) => ({
  name: stone.name,
  image: stone.image,
}));
---

<Layout title={title} description={description}>
  <Fragment slot="head">
    <!-- Preload Hero Image -->
    <link
      rel="preload"
      as="image"
      href={heroImage.src}
      fetchpriority="high"
    />
    <!-- SEO Meta Tags -->
    <meta name="keywords" content={keywords} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Mármoles Deluxe" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={metaImage} />
    <meta property="og:locale" content="es_CO" />
    <meta property="og:site_name" content="Mármoles Deluxe" />

    <!-- Twitter Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={metaImage} />

    <!-- Geo Tags -->
    <meta name="geo.region" content="CO-VAC" />
    <meta name="geo.placename" content="Cali" />
    <meta name="geo.position" content="3.4516;-76.5320" />
    <meta name="ICBM" content="3.4516, -76.5320" />
  </Fragment>

  <!-- Agregar datos estructurados schema.org para SEO -->
  <SEOSchemaData
    pageTitle={title}
    pageDescription={description}
    pageUrl={pageUrl}
    pageImage={metaImage}
    category="Granitos Naturales"
    stones={schemaStones}
  />

  <main class="pt-20">
    <!-- Hero Banner con Imagen Real de Granito -->
    <section class="relative h-80 md:h-[450px] flex items-center justify-center overflow-hidden bg-marmoles-black text-white mb-12">
      <div class="absolute inset-0 z-0">
        <img
          src={heroImage.src}
          srcset={heroImage.srcSet}
          sizes={heroImage.sizes}
          alt="Mesón de cocina en Granito Natural Negro San Gabriel instalado en Cali"
          class="w-full h-full object-cover opacity-50"
          width="1200"
          height="450"
          fetchpriority="high"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-marmoles-black via-marmoles-black/40 to-transparent"></div>
      </div>
      <div class="container mx-auto px-4 z-10 text-center">
        <h1 class="text-4xl md:text-6xl font-bold tracking-tight mb-2">
          Granitos Naturales
        </h1>
        <p class="text-lg md:text-xl text-gray-200 max-w-2xl mx-auto font-light">
          Elegancia, robustez y durabilidad natural para superficies en Cali
        </p>
      </div>
    </section>

    <div class="container mx-auto px-4">

      <!-- Features como subtítulo -->
      <div class="max-w-5xl mx-auto mb-12">
        <div
          class="bg-gradient-to-r from-gray-50 to-white p-6 rounded-lg shadow-sm border border-gray-100"
        >
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
            <div class="flex items-start text-sm text-gray-700">
              <span class="mr-2 flex-shrink-0">✔</span>
              <span>Resistente a manchas y líquidos</span>
            </div>
            <div class="flex items-start text-sm text-gray-700">
              <span class="mr-2 flex-shrink-0">✔</span>
              <span>Alta durabilidad y longevidad</span>
            </div>
            <div class="flex items-start text-sm text-gray-700">
              <span class="mr-2 flex-shrink-0">✔</span>
              <span>Elegancia natural única</span>
            </div>
            <div class="flex items-start text-sm text-gray-700">
              <span class="mr-2 flex-shrink-0">✔</span>
              <span>Resistente al calor intenso</span>
            </div>
          </div>
        </div>
      </div>

      <div
        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 xl:grid-cols-3 gap-8 mb-16"
        id="granitos-grid"
      >
        {
          granitosNaturales.map((stone: Stone) => (
            <ProductCard
              client:idle
              name={stone.name}
              description="Granito natural de alta calidad"
              images={[stone.image, stone.design]}
              category="Granito Natural"
              slug={stone.name
                .toLowerCase()
                .replace(/[^a-z0-9]+/g, "-")
                .replace(/(^-|-$)/g, "")}
            />
          ))
        }
      </div>
    </div>
  </main>
</Layout>

<script>
  import { initModal } from "../scripts/modal";
  initModal();

  // --- Abrir modal automáticamente por parámetro 'material' ---
  if (typeof window !== "undefined") {
    window.addEventListener("DOMContentLoaded", () => {
      const params = new URLSearchParams(window.location.search);
      const material = params.get("material");
      if (material) {
        setTimeout(() => {
          const event = new CustomEvent("modal-state-change", {
            detail: { id: material },
          });
          document.dispatchEvent(event);
        }, 500);
      }
    });
  }
</script>
