---
import LocalSeoLanding from "../components/LocalSeoLanding.astro";

const faqs = [
  {
    question: "¿Atienden condominios y conjuntos en Jamundí?",
    answer:
      "Sí. Tenemos operación para viviendas en Jamundí y coordinamos acceso, tiempos de obra y restricciones de administración.",
  },
  {
    question: "¿Qué material funciona mejor para cocinas familiares?",
    answer:
      "Cuarzo y piedra sinterizada suelen ofrecer mejor balance entre estética, resistencia y facilidad de limpieza para uso diario.",
  },
  {
    question: "¿Cómo se define el precio final?",
    answer:
      "Se define por metraje, material, tipo de borde, perforaciones y complejidad de instalación luego de la visita técnica.",
  },
];
---

<LocalSeoLanding
  seo={{
    title: "Mesones de Cocina en Jamundí | Mármoles Deluxe",
    description:
      "Mesones de cocina en Jamundí con instalación profesional. Cuarzo, granito y piedra sinterizada para proyectos residenciales.",
    canonical: "/mesones-de-cocina-jamundi",
    primaryKeyword: "mesones de cocina jamundi, marmoleria jamundi",
    localArea: "Jamundí",
    schemaType: "Service",
    faq: faqs,
  }}
  h1="Mesones de Cocina en Jamundí para Vivienda y Condominio"
  heroIntro="Diseñamos e instalamos superficies para cocina en Jamundí con materiales de larga vida útil, control de calidad y un flujo operativo adaptado a proyectos residenciales."
  bodyText={`En Jamundí atendemos proyectos nuevos y remodelaciones. El flujo parte de una visita técnica para definir metraje, puntos hidráulicos, tipo de material y acabados. Luego fabricamos y coordinamos montaje con tiempos claros.

Nuestro enfoque evita cotizaciones ambiguas: se documenta alcance, se valida disponibilidad de material y se definen condiciones de instalación desde el inicio. Eso reduce cambios de última hora y mejora la experiencia del cliente.`}
  trustTitle="Ejecución ordenada para proyectos en Jamundí"
  trustAnswer="La prioridad en Jamundí es combinar diseño con operación predecible. Eso implica materiales adecuados al uso real, una propuesta económica clara y un montaje con control técnico."
  trustBullets={[
    "Atención a conjuntos y viviendas con coordinación previa de acceso.",
    "Criterio técnico para seleccionar material según uso y presupuesto.",
    "Instalación con control de nivelación, uniones y limpieza final.",
  ]}
  faqs={faqs}
  ctaHref="https://wa.me/573132592793?text=Hola%2C%20quiero%20cotizar%20un%20mes%C3%B3n%20de%20cocina%20en%20Jamund%C3%AD."
  ctaLabel="Cotizar en Jamundí"
  secondaryHref="/precios"
  secondaryLabel="Ver guía de precios"
/>
