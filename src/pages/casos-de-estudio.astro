---
import Layout from "../layouts/Layout.astro";
import GeoBusinessSchema from "../components/GeoBusinessSchema.astro";
import GeoFaqSection from "../components/GeoFaqSection.astro";
import GeoTrustSection from "../components/GeoTrustSection.astro";
import { cloudinaryAssets } from "../lib/images/cloudinaryAssets";
import { buildSeoImageUrl } from "../lib/images/cloudinary";
import { caseStudies } from "../data/caseStudies";

const title =
  "Casos de Estudio - Mármoles Deluxe | Proyectos, materiales y tiempos reales";
const description =
  "Explora casos de estudio de Mármoles Deluxe con materiales, aplicaciones, tiempos de ejecución, alcance, retos y resultados en proyectos residenciales y comerciales en Cali.";
const keywords =
  "casos de estudio marmoles Cali, proyectos piedra sinterizada Cali, proyectos neolith Cali, proyectos altea Cali, proyectos granito Cali, instalación 5 días, portafolio marmoles deluxe";
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const pageUrl = canonicalURL.toString();
const metaImage = buildSeoImageUrl(cloudinaryAssets.seo.projects);

const faqItems = [
  {
    question: "¿Cuánto tarda normalmente un proyecto de cubiertas o superficies premium?",
    answer:
      "En proyectos residenciales bien definidos, el proceso completo puede resolverse en una ventana cercana a 5 días entre medición, fabricación, instalación y entrega final. El tiempo exacto depende del material, el formato, los recortes especiales y la logística de acceso.",
  },
  {
    question: "¿Qué material conviene para una cocina de uso diario?",
    answer:
      "Para cocinas de uso frecuente suelen destacarse las superficies sinterizadas y algunos cuarzos por su mantenimiento simple, estabilidad visual y buen desempeño frente a manchas y uso continuo. La elección final depende del estilo del proyecto y de cómo se utiliza el espacio.",
  },
  {
    question: "¿La piedra sinterizada sirve también para barras, baños o proyectos comerciales?",
    answer:
      "Sí. La piedra sinterizada funciona muy bien en barras, baños, revestimientos y superficies comerciales cuando se especifica correctamente el formato, el espesor y el sistema de instalación según el uso esperado.",
  },
  {
    question: "¿Qué revisa Mármoles Deluxe antes de recomendar un material?",
    answer:
      "Se revisan medidas, tipo de uso, exposición al calor o la humedad, continuidad visual, tránsito esperado, logística de acceso y acabado deseado. La recomendación no se hace solo por catálogo, sino por compatibilidad real con el proyecto.",
  },
];

const caseStudiesSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: title,
  description,
  url: pageUrl,
  hasPart: caseStudies.map((study, index) => ({
    "@type": "Article",
    headline: study.title,
    description: study.summary,
    position: index + 1,
    datePublished: study.publishedAt,
    dateModified: study.updatedAt,
    image: study.images.cover,
    author: {
      "@type": "Organization",
      name: study.authorName,
    },
    about: [
      study.materialBrand,
      study.application,
      study.location,
      study.propertyType,
    ],
  })),
};
---

<Layout title={title} description={description}>
  <Fragment slot="head">
    <meta name="keywords" content={keywords} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Mármoles Deluxe" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={metaImage} />
    <meta property="og:locale" content="es_CO" />
    <meta property="og:site_name" content="Mármoles Deluxe" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={metaImage} />

    <script type="application/ld+json" set:html={JSON.stringify(caseStudiesSchema)} />
  </Fragment>

  <GeoBusinessSchema
    pageTitle={title}
    pageDescription={description}
    pageUrl={pageUrl}
    pageImage={metaImage}
    pageType="CollectionPage"
    faqs={faqItems}
  />

  <main class="pt-24 pb-20 bg-gray-50">
    <section class="relative overflow-hidden bg-marmoles-black text-white py-20">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(212,175,55,0.28),transparent_36%),radial-gradient(circle_at_bottom_left,rgba(255,255,255,0.06),transparent_32%)]"></div>
      <div class="container mx-auto px-4 sm:px-6 max-w-6xl relative z-10">
        <div class="max-w-4xl">
          <h1 class="text-4xl md:text-6xl font-bold leading-tight mb-6">
            Casos de estudio de superficies premium en Cali
          </h1>
          <p class="text-lg md:text-2xl text-gray-300 max-w-3xl mb-8">
            Descubre cómo resolvemos cocinas, barras y proyectos comerciales con
            mármoles, granitos y piedra sinterizada. Cada caso resume el reto,
            el material seleccionado, el tiempo de ejecución y el resultado final.
          </p>
          <div class="flex flex-wrap gap-3 text-sm">
            <span class="rounded-full border border-marmoles-gold/40 bg-marmoles-gold/10 px-4 py-2 text-marmoles-gold">
              Proyectos residenciales y comerciales
            </span>
            <span class="rounded-full border border-white/20 bg-white/5 px-4 py-2 text-gray-200">
              Instalación planificada en 5 días
            </span>
            <span class="rounded-full border border-white/20 bg-white/5 px-4 py-2 text-gray-200">
              Materiales y alcances explicados
            </span>
          </div>
        </div>
      </div>
    </section>

    <GeoTrustSection
      title="Cómo trabajamos proyectos residenciales y comerciales con criterio técnico"
      answer="Cada caso de estudio resume una intervención realista: qué necesitaba el espacio, qué material respondía mejor al uso, cómo se organizó la fabricación y qué resultado se buscó en términos de durabilidad, limpieza visual y experiencia de uso."
      bullets={[
        "Selección de material según uso, mantenimiento y lectura estética del ambiente.",
        "Cronograma resumido para entender cómo se ejecuta una obra corta y bien planificada.",
        "Casos pensados para inspirar decisiones reales en cocina, barra, baño y comercio.",
      ]}
    />
    <section class="py-8">
      <div class="container mx-auto px-4 sm:px-6 max-w-6xl">
        <div class="rounded-2xl border border-gray-200 bg-white p-6">
          <h2 class="text-2xl font-bold text-marmoles-black mb-3">
            Páginas técnicas por marca sinterizada
          </h2>
          <p class="text-gray-700 mb-4">
            Si buscas especificar material por desempeño, revisa las rutas por marca en Cali:
          </p>
          <div class="flex flex-wrap gap-3 text-sm">
            <a href="/piedra-sinterizada/altea" class="text-marmoles-gold font-semibold hover:underline">Altea</a>
            <a href="/piedra-sinterizada/dekton" class="text-marmoles-gold font-semibold hover:underline">Dekton</a>
            <a href="/piedra-sinterizada/neolith" class="text-marmoles-gold font-semibold hover:underline">Neolith</a>
            <a href="/piedra-sinterizada/silestone" class="text-marmoles-gold font-semibold hover:underline">Silestone</a>
            <a href="/piedra-sinterizada/terracina" class="text-marmoles-gold font-semibold hover:underline">Terracina</a>
            <a href="/piedra-sinterizada/artemarmol" class="text-marmoles-gold font-semibold hover:underline">Artemarmol</a>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16">
      <div class="container mx-auto px-4 sm:px-6 max-w-6xl">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {
            caseStudies.map((study) => (
              <article class="rounded-3xl overflow-hidden bg-white shadow-xl border border-gray-100">
                <img
                  src={study.images.cover}
                  alt={`Placeholder visual del caso ${study.title}`}
                  class="h-64 w-full object-cover"
                  loading="lazy"
                />
                <div class="p-6">
                  <div class="flex flex-wrap gap-2 mb-4 text-xs font-semibold uppercase tracking-[0.18em] text-gray-500">
                    <span>{study.materialBrand}</span>
                    <span>{study.location}</span>
                  </div>
                  <h2 class="text-2xl font-bold text-marmoles-black mb-3">
                    <a href={`#${study.slug}`} class="hover:text-marmoles-gold transition-colors">
                      {study.title}
                    </a>
                  </h2>
                  <p class="text-gray-600 leading-relaxed mb-5">{study.summary}</p>
                  <dl class="grid grid-cols-2 gap-3 text-sm">
                    <div class="rounded-2xl bg-gray-50 p-3">
                      <dt class="text-gray-500">Aplicación</dt>
                      <dd class="font-semibold text-marmoles-black">{study.application}</dd>
                    </div>
                    <div class="rounded-2xl bg-gray-50 p-3">
                      <dt class="text-gray-500">Tiempo</dt>
                      <dd class="font-semibold text-marmoles-black">{study.timelineDays} días</dd>
                    </div>
                  </dl>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="pb-8">
      <div class="container mx-auto px-4 sm:px-6 max-w-6xl space-y-16">
        {
          caseStudies.map((study) => (
            <article
              id={study.slug}
              class="rounded-[2rem] border border-gray-200 bg-white shadow-xl overflow-hidden"
            >
              <div class="grid grid-cols-1 lg:grid-cols-[1.15fr_0.85fr]">
                <div class="p-8 md:p-10 border-b lg:border-b-0 lg:border-r border-gray-100">
                  <div class="flex flex-wrap gap-3 mb-5 text-sm">
                    <span class="rounded-full bg-marmoles-gold/10 px-4 py-2 font-semibold text-marmoles-gold">
                      {study.materialBrand}
                    </span>
                    <span class="rounded-full bg-gray-100 px-4 py-2 text-gray-700">
                      {study.location}
                    </span>
                    <span class="rounded-full bg-gray-100 px-4 py-2 text-gray-700">Actualizado {study.updatedAt}</span>
                  </div>
                  <h2 class="text-3xl md:text-4xl font-bold text-marmoles-black mb-4">
                    {study.title}
                  </h2>
                  <p class="text-lg leading-relaxed text-gray-700 mb-8">
                    {study.summary}
                  </p>

                  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
                    <div class="rounded-2xl bg-gray-50 p-5">
                      <h3 class="font-semibold text-marmoles-black mb-2">Material</h3>
                      <p class="text-gray-700">
                        {study.materialBrand} · {study.materialLine}
                        <br />
                        <span class="text-sm text-gray-500">{study.materialReference}</span>
                      </p>
                    </div>
                    <div class="rounded-2xl bg-gray-50 p-5">
                      <h3 class="font-semibold text-marmoles-black mb-2">Aplicación</h3>
                      <p class="text-gray-700">{study.application}</p>
                    </div>
                    <div class="rounded-2xl bg-gray-50 p-5">
                      <h3 class="font-semibold text-marmoles-black mb-2">Tipo de proyecto</h3>
                      <p class="text-gray-700">{study.propertyType}</p>
                    </div>
                    <div class="rounded-2xl bg-gray-50 p-5">
                      <h3 class="font-semibold text-marmoles-black mb-2">Tiempo real</h3>
                      <p class="text-gray-700">{study.timelineLabel}</p>
                    </div>
                  </div>

                  <div class="space-y-8">
                    <section>
                      <h3 class="text-2xl font-bold text-marmoles-black mb-3">Reto del proyecto</h3>
                      <p class="text-gray-700 leading-relaxed">{study.challenge}</p>
                    </section>
                    <section>
                      <h3 class="text-2xl font-bold text-marmoles-black mb-3">Solución propuesta</h3>
                      <p class="text-gray-700 leading-relaxed">{study.solution}</p>
                    </section>
                    <section>
                      <h3 class="text-2xl font-bold text-marmoles-black mb-3">Resultado</h3>
                      <p class="text-gray-700 leading-relaxed">{study.result}</p>
                    </section>
                    <section>
                      <h3 class="text-2xl font-bold text-marmoles-black mb-3">Alcance del trabajo</h3>
                      <ul class="grid grid-cols-1 md:grid-cols-2 gap-3 text-gray-700">
                        {study.scope.map((item) => <li class="rounded-2xl bg-gray-50 p-4">{item}</li>)}
                      </ul>
                    </section>
                    <section>
                      <h3 class="text-2xl font-bold text-marmoles-black mb-3">Cronograma explicado</h3>
                      <ol class="space-y-3 text-gray-700">
                        {study.timelineBreakdown.map((item) => <li class="rounded-2xl bg-gray-50 p-4">{item}</li>)}
                      </ol>
                    </section>
                  </div>
                </div>

                <aside class="p-8 md:p-10 bg-gray-50">
                  <div class="rounded-3xl overflow-hidden bg-white shadow-lg mb-6">
                    <img
                      src={study.images.final}
                      alt={`Placeholder final del caso ${study.title}`}
                      class="w-full h-72 object-cover"
                      loading="lazy"
                    />
                  </div>
                  <div class="grid grid-cols-2 gap-4 mb-8">
                    <img src={study.images.before} alt={`Placeholder antes del caso ${study.title}`} class="w-full h-40 object-cover rounded-2xl shadow-md" loading="lazy" />
                    <img src={study.images.process} alt={`Placeholder proceso del caso ${study.title}`} class="w-full h-40 object-cover rounded-2xl shadow-md" loading="lazy" />
                  </div>

                  <div class="rounded-3xl bg-marmoles-black text-white p-6 mb-6">
                    <p class="text-xs uppercase tracking-[0.2em] text-marmoles-gold mb-3">
                      Responsable del caso
                    </p>
                    <h3 class="text-xl font-bold mb-2">{study.authorName}</h3>
                    <p class="text-gray-300">{study.authorRole}</p>
                    <p class="text-sm text-gray-400 mt-4">
                      Publicado {study.publishedAt} · Actualizado {study.updatedAt}
                    </p>
                  </div>

                  <blockquote class="rounded-3xl bg-white p-6 shadow-md border border-gray-200">
                    <p class="text-lg text-gray-700 leading-relaxed mb-4">“{study.testimonial.quote}”</p>
                    <footer class="text-sm text-gray-500">
                      <strong class="text-marmoles-black">{study.testimonial.name}</strong>
                      <br />
                      {study.testimonial.role}
                    </footer>
                  </blockquote>

                </aside>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <GeoFaqSection
      title="Preguntas frecuentes sobre materiales, tiempos y ejecución"
      intro="Estas respuestas resumen dudas comunes cuando un cliente quiere comparar materiales, entender tiempos de obra y evaluar qué solución se adapta mejor a su proyecto."
      faqs={faqItems}
    />
    <section class="py-10">
      <div class="container mx-auto px-4 sm:px-6 max-w-6xl">
        <div class="rounded-2xl border border-gray-200 bg-white p-6">
          <h2 class="text-2xl font-bold text-marmoles-black mb-3">
            Continuar evaluación comercial
          </h2>
          <p class="text-gray-700 mb-4">
            Después de revisar casos reales, usa estas rutas para cerrar comparación y cotización.
          </p>
          <div class="flex flex-wrap gap-3 text-sm">
            <a href="/mesones-de-cocina" class="text-marmoles-gold font-semibold hover:underline">Mesones y encimeras de cocina en Cali</a>
            <a href="/precios" class="text-marmoles-gold font-semibold hover:underline">Guía de precios por material</a>
            <a href="/blanco-polar" class="text-marmoles-gold font-semibold hover:underline">Referencia Blanco Polar en cuarzo</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
