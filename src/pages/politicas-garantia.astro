---
import Layout from "../layouts/Layout.astro";

const title = "Políticas de Garantía y Servicios - Mármoles Deluxe Cali";
const description =
  "Garantías certificadas para mármol, granito, cuarzo y piedra sinterizada en Cali. 1 año mano de obra, hasta 25 años en materiales. Normativas NTC 4489, ISO 9001:2015, Ley 1480 de 2011. Cobertura técnica completa.";

const keywords =
  "garantías mármol Cali, garantía granito, cuarzo quartzstone garantía, piedra sinterizada garantía, NTC 4489, ISO 9001, políticas calidad mármoles, servicio postventa Cali, garantía instalación piedra, mantenimiento mármol granito";

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const schemaData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: title,
  description: description,
  url: canonicalURL.href,
  inLanguage: "es-CO",
  isPartOf: {
    "@type": "WebSite",
    name: "Mármoles Deluxe",
    url: Astro.site?.href,
  },
  about: {
    "@type": "Service",
    serviceType: "Garantía y Servicio Postventa",
    provider: {
      "@type": "LocalBusiness",
      name: "Mármoles Deluxe",
      "@id": "https://marmolesdeluxe.com/#organization",
      address: {
        "@type": "PostalAddress",
        streetAddress: "Cra 5norte 40-43 barrio el popular",
        addressLocality: "Cali",
        addressRegion: "Valle del Cauca",
        addressCountry: "CO",
      },
      telephone: "+57-313-2592793",
      email: "marmolesdeluxe@gmail.com",
    },
    areaServed: {
      "@type": "City",
      name: "Cali",
      containedIn: {
        "@type": "State",
        name: "Valle del Cauca",
      },
    },
  },
  mainEntity: {
    "@type": "FAQPage",
    mainEntity: [
      {
        "@type": "Question",
        name: "¿Cuánto dura la garantía de mano de obra?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "La garantía de mano de obra de Mármoles Deluxe es de 12 meses a partir de la fecha de entrega del proyecto, cubriendo instalación, corte, pulido y acabados según NTC 5828.",
        },
      },
      {
        "@type": "Question",
        name: "¿Qué material tiene la mayor garantía?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "La piedra sinterizada ofrece la mayor garantía del fabricante, entre 10-25 años, debido a su proceso de fabricación a 1,200°C y 25,000 toneladas de presión, que la hace extremadamente resistente.",
        },
      },
      {
        "@type": "Question",
        name: "¿El cuarzo (quartzstone) resiste el calor?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "No. El cuarzo ingenieril tiene resistencia térmica limitada hasta 80-100°C. Las resinas poliméricas se dañan con calor directo. Siempre use protectores térmicos para ollas y sartenes calientes.",
        },
      },
      {
        "@type": "Question",
        name: "¿Qué normativas técnicas cumplen?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Cumplimos con NTC 4489 (Piedras Naturales), NTC 5828 (Instalación), ISO 9001:2015 (Gestión de Calidad), ISO 10545 (Sinterizados) y Ley 1480 de 2011 (Estatuto del Consumidor).",
        },
      },
    ],
  },
};
---

<Layout title={title} description={description}>
  <Fragment slot="head">
    <!-- SEO Meta Tags -->
    <meta name="keywords" content={keywords} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Mármoles Deluxe" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="es_CO" />
    <meta property="og:site_name" content="Mármoles Deluxe" />

    <!-- Geo Tags -->
    <meta name="geo.region" content="CO-VAC" />
    <meta name="geo.placename" content="Cali" />
    <meta name="geo.position" content="3.4516;-76.5320" />
    <meta name="ICBM" content="3.4516, -76.5320" />

    <!-- JSON-LD Schema -->
    <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
  </Fragment>

  <div class="min-h-screen bg-gradient-to-br from-gray-50 to-gray-100">
    <!-- Hero Section -->
    <section
      class="bg-gradient-to-r from-gray-900 via-black to-black text-white py-20 relative overflow-hidden"
    >
      <div
        class="absolute inset-0 bg-gradient-to-br from-marmoles-gold/10 to-transparent"
      >
      </div>
      <div class="container mx-auto px-4 max-w-6xl">
        <div class="text-center">
          <h1 class="text-5xl font-bold mb-6">
            Políticas de Garantía y Servicios
          </h1>
          <p class="text-xl text-white/90 max-w-3xl mx-auto">
            Comprometidos con la excelencia y calidad en cada proyecto.
            Garantías certificadas conforme a normativas técnicas colombianas
            2025.
          </p>
          <div class="mt-8 flex justify-center gap-4 text-sm">
            <span
              class="bg-marmoles-gold/20 border border-marmoles-gold/30 px-4 py-2 rounded-full"
              >✓ NTC 4489 - Piedras Naturales</span
            >
            <span
              class="bg-marmoles-gold/20 border border-marmoles-gold/30 px-4 py-2 rounded-full"
              >✓ ISO 9001:2015</span
            >
            <span
              class="bg-marmoles-gold/20 border border-marmoles-gold/30 px-4 py-2 rounded-full"
              >✓ Ley 1480 de 2011</span
            >
          </div>
        </div>
      </div>
    </section>

    <div class="container mx-auto px-4 max-w-6xl py-16">
      <!-- Garantía de Mano de Obra -->
      <section
        class="mb-16 bg-white rounded-2xl shadow-xl p-8 border-l-8 border-marmoles-gold"
      >
        <div class="flex items-start gap-4 mb-6">
          <div class="text-5xl">🔧</div>
          <div>
            <h2 class="text-3xl font-bold text-gray-900 mb-2">
              Garantía de Mano de Obra
            </h2>
            <p class="text-lg text-marmoles-gold font-semibold">
              1 Año de Cobertura Total
            </p>
          </div>
        </div>

        <div class="space-y-4 text-gray-700">
          <p class="text-lg leading-relaxed">
            Mármoles Deluxe garantiza la calidad de todos nuestros trabajos de
            instalación, corte, pulido y acabados por un período de <strong
              class="text-marmoles-gold">12 meses</strong
            > a partir de la fecha de entrega del proyecto.
          </p>

          <div
            class="bg-blue-50 border-l-4 border-blue-500 p-6 rounded-r-lg my-6"
          >
            <h3 class="font-bold text-gray-900 mb-3 text-lg">
              ✓ Cobertura de Mano de Obra Incluye:
            </h3>
            <ul class="space-y-2 ml-4">
              <li class="flex items-start gap-2">
                <span class="text-blue-600 mt-1">•</span>
                <span
                  ><strong>Desprendimientos o desplazamientos</strong> de piezas instaladas
                  por defectos en adhesivos, anclajes o nivelación</span
                >
              </li>
              <li class="flex items-start gap-2">
                <span class="text-blue-600 mt-1">•</span>
                <span
                  ><strong>Fisuras en juntas de instalación</strong> causadas por
                  aplicación defectuosa de selladores o morteros</span
                >
              </li>
              <li class="flex items-start gap-2">
                <span class="text-blue-600 mt-1">•</span>
                <span
                  ><strong>Nivelación inadecuada</strong> de superficies que genere
                  acumulación de agua o desniveles mayores a 2mm/m según NTC 5828</span
                >
              </li>
              <li class="flex items-start gap-2">
                <span class="text-blue-600 mt-1">•</span>
                <span
                  ><strong>Roturas por corte inadecuado</strong> o errores de medición
                  atribuibles a nuestro personal técnico</span
                >
              </li>
              <li class="flex items-start gap-2">
                <span class="text-blue-600 mt-1">•</span>
                <span
                  ><strong>Filtración de agua</strong> en juntas de encimeras, backsplash
                  o zonas húmedas por sellado defectuoso</span
                >
              </li>
            </ul>
          </div>

          <div class="bg-red-50 border-l-4 border-red-500 p-6 rounded-r-lg">
            <h3 class="font-bold text-gray-900 mb-3 text-lg">
              ✗ Exclusiones de Garantía de Mano de Obra:
            </h3>
            <ul class="space-y-2 ml-4 text-gray-700">
              <li class="flex items-start gap-2">
                <span class="text-red-600 mt-1">•</span>
                <span
                  >Daños causados por <strong
                    >mal uso, impactos, cargas excesivas</strong
                  > o uso inadecuado de la superficie</span
                >
              </li>
              <li class="flex items-start gap-2">
                <span class="text-red-600 mt-1">•</span>
                <span
                  >Deterioro por <strong>productos químicos agresivos</strong> (ácidos,
                  removedores, solventes no recomendados)</span
                >
              </li>
              <li class="flex items-start gap-2">
                <span class="text-red-600 mt-1">•</span>
                <span
                  >Modificaciones o reparaciones realizadas por <strong
                    >terceros no autorizados</strong
                  ></span
                >
              </li>
              <li class="flex items-start gap-2">
                <span class="text-red-600 mt-1">•</span>
                <span
                  >Desgaste natural por <strong>tráfico intenso</strong> en zonas
                  comerciales o industriales</span
                >
              </li>
              <li class="flex items-start gap-2">
                <span class="text-red-600 mt-1">•</span>
                <span
                  >Daños por <strong>sismos, inundaciones, incendios</strong> u otros
                  eventos de fuerza mayor</span
                >
              </li>
            </ul>
          </div>
        </div>
      </section>

      <!-- Garantías por Tipo de Material -->
      <section class="mb-16">
        <h2 class="text-4xl font-bold text-gray-900 mb-8 text-center">
          🪨 Garantías Específicas por Material
        </h2>
        <p class="text-center text-gray-600 mb-12 max-w-3xl mx-auto">
          Cada material natural o sintético posee características únicas. Las
          garantías se ajustan a las normativas técnicas y especificaciones del
          fabricante.
        </p>

        <!-- Mármol -->
        <div
          class="bg-white rounded-2xl shadow-lg p-8 mb-8 border-t-4 border-gray-400"
        >
          <div class="flex items-start gap-4 mb-6">
            <div class="text-4xl">🏛️</div>
            <div class="flex-1">
              <h3 class="text-2xl font-bold text-gray-900 mb-2">
                Mármol Natural
              </h3>
              <p class="text-sm text-gray-500 uppercase tracking-wide">
                Garantía (defectos estructurales) | Veteado y tonalidad: Sin
                garantía (variación natural)
              </p>
            </div>
          </div>

          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <h4 class="font-bold text-gray-900 mb-3 flex items-center gap-2">
                <span class="text-green-600">✓</span> Características Técnicas
              </h4>
              <ul class="space-y-2 text-sm text-gray-700">
                <li>
                  • <strong>Composición:</strong> Carbonato de calcio (CaCO₃) metamorfizado
                </li>
                <li>
                  • <strong>Dureza Mohs:</strong> 3-4 (Media-baja, susceptible a rayones)
                </li>
                <li>
                  • <strong>Densidad:</strong> 2.6-2.8 g/cm³ según NTC 4489
                </li>
                <li>
                  • <strong>Absorción de agua:</strong> 0.2-0.4% (porosidad moderada
                  - se mancha fácilmente)
                </li>
                <li>• <strong>Resistencia a compresión:</strong> 70-170 MPa</li>
                <li>
                  • <strong>Sensibilidad a ácidos:</strong> ⚠️ ALTA (reacciona con
                  limón, vinagre, productos de limpieza ácidos)
                </li>
                <li>
                  • <strong>Susceptibilidad a manchas:</strong> ⚠️ ALTA (absorbe líquidos
                  como aceite, vino, café, jugos)
                </li>
              </ul>
            </div>

            <div>
              <h4 class="font-bold text-gray-900 mb-3 flex items-center gap-2">
                <span class="text-blue-600">📋</span> Cobertura de Garantía
              </h4>
              <ul class="space-y-2 text-sm text-gray-700">
                <li>
                  ✓ Fisuras o grietas estructurales no visibles al momento de la
                  compra
                </li>
                <li>
                  ✓ Desprendimiento de capas superficiales por defectos de
                  cantera
                </li>
                <li>✓ Manchas internas no atribuibles a derrames externos</li>
                <li class="text-red-600 font-semibold">
                  ✗ Manchas por ácidos (vino, café, limón, productos de
                  limpieza)
                </li>
                <li class="text-red-600 font-semibold">
                  ✗ Opacamiento por uso de productos inadecuados
                </li>
                <li class="text-red-600 font-semibold">
                  ✗ Rayones por objetos cortantes o abrasivos
                </li>
                <li class="text-red-600 font-semibold">
                  ✗ Variaciones naturales de veteado entre lotes
                </li>
              </ul>
            </div>
          </div>

          <div
            class="mt-6 bg-yellow-50 border border-yellow-200 rounded-lg p-4"
          >
            <p class="text-sm text-yellow-800">
              <strong>⚠️ Importante:</strong> El mármol es una piedra natural con
              variaciones únicas. El veteado, tonalidad y patrones son características
              inherentes y pueden variar entre piezas del mismo lote. Esto no constituye
              defecto.
            </p>
          </div>
        </div>

        <!-- Granito -->
        <div
          class="bg-white rounded-2xl shadow-lg p-8 mb-8 border-t-4 border-gray-600"
        >
          <div class="flex items-start gap-4 mb-6">
            <div class="text-4xl">⛰️</div>
            <div class="flex-1">
              <h3 class="text-2xl font-bold text-gray-900 mb-2">
                Granito Natural
              </h3>
              <p class="text-sm text-gray-500 uppercase tracking-wide">
                Garantía (defectos estructurales) | Mayor durabilidad que mármol
              </p>
            </div>
          </div>

          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <h4 class="font-bold text-gray-900 mb-3 flex items-center gap-2">
                <span class="text-green-600">✓</span> Características Técnicas
              </h4>
              <ul class="space-y-2 text-sm text-gray-700">
                <li>
                  • <strong>Composición:</strong> Cuarzo (20-60%), feldespato, mica
                </li>
                <li>
                  • <strong>Dureza Mohs:</strong> 6-7 (resistente pero puede rayarse
                  con uso intensivo)
                </li>
                <li>• <strong>Densidad:</strong> 2.65-2.75 g/cm³</li>
                <li>
                  • <strong>Absorción de agua:</strong> &lt;0.4% (muy baja porosidad
                  - se recomienda sellado periódico cada 6 meses)
                </li>
                <li>
                  • <strong>Resistencia a compresión:</strong> 100-250 MPa
                </li>
                <li>
                  • <strong>Resistencia térmica:</strong> ⚠️ Hasta 150°C (puede agrietarse
                  con cambios bruscos)
                </li>
                <li>
                  • <strong>Resistencia a ácidos:</strong> ⚠️ MEDIA (puede mancharse
                  con ácidos fuertes o exposición prolongada)
                </li>
                <li>
                  • <strong>Resistencia a rayones:</strong> ⚠️ MODERADA (puede rayarse
                  con objetos metálicos, uso de tablas recomendado)
                </li>
                <li>
                  • <strong>Productos de limpieza:</strong> ⚠️ Usar solo pH neutro
                  (evitar limpiadores convencionales con químicos fuertes)
                </li>
              </ul>
            </div>

            <div>
              <h4 class="font-bold text-gray-900 mb-3 flex items-center gap-2">
                <span class="text-blue-600">📋</span> Cobertura de Garantía
              </h4>
              <ul class="space-y-2 text-sm text-gray-700">
                <li>
                  ✓ Grietas estructurales por defectos de formación geológica
                </li>
                <li>
                  ✓ Delaminación o desprendimiento de minerales constitutivos
                </li>
                <li>
                  ✓ Cambios de color por oxidación interna de minerales ferrosos
                </li>
                <li>
                  ✓ Pérdida de brillo por cristalización defectuosa del material
                </li>
                <li class="text-red-600 font-semibold">
                  ✗ Roturas por impactos directos o cargas puntuales excesivas
                </li>
                <li class="text-red-600 font-semibold">
                  ✗ Fisuras por choque térmico (ollas calientes directamente
                  sobre la superficie)
                </li>
                <li class="text-red-600 font-semibold">
                  ✗ Manchas por sustancias colorantes penetrantes (aceites,
                  vino) en granitos porosos
                </li>
                <li class="text-red-600 font-semibold">
                  ✗ Rayones por uso intensivo, objetos metálicos o corte directo
                  sin tabla
                </li>
              </ul>
            </div>
          </div>

          <div
            class="mt-6 bg-yellow-50 border border-yellow-300 rounded-lg p-4"
          >
            <p class="text-sm text-yellow-800">
              <strong>⚠️ Importante sobre el Granito:</strong> Aunque es una piedra
              natural resistente para encimeras, es susceptible a rayones con uso
              intensivo o corte directo. Se recomienda usar tablas de cortar para
              preservar el acabado. Es resistente a manchas si está sellado correctamente
              y no se daña con productos de limpieza convencionales. Los rayones por
              uso normal NO están cubiertos por garantía.
            </p>
          </div>
        </div>

        <!-- Quartzstone / Cuarzo Ingenieril -->
        <div
          class="bg-white rounded-2xl shadow-lg p-8 mb-8 border-t-4 border-purple-600"
        >
          <div class="flex items-start gap-4 mb-6">
            <div class="text-4xl">💎</div>
            <div class="flex-1">
              <h3 class="text-2xl font-bold text-gray-900 mb-2">
                Quartzstone (Cuarzo Ingenieril)
              </h3>
              <p class="text-sm text-gray-500 uppercase tracking-wide">
                Garantía del Fabricante | Material Sintético de Alta Tecnología
              </p>
            </div>
          </div>

          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <h4 class="font-bold text-gray-900 mb-3 flex items-center gap-2">
                <span class="text-green-600">✓</span> Características Técnicas
              </h4>
              <ul class="space-y-2 text-sm text-gray-700">
                <li>
                  • <strong>Composición:</strong> 90-94% cuarzo natural + 6-10% resinas
                  poliméricas y pigmentos
                </li>
                <li>
                  • <strong>Dureza Mohs:</strong> 7 (Superior al granito natural)
                </li>
                <li>• <strong>Densidad:</strong> 2.3-2.4 g/cm³</li>
                <li>
                  • <strong>Absorción de agua:</strong> &lt;0.05% (prácticamente nulo,
                  no requiere sellado)
                </li>
                <li>
                  • <strong>Resistencia a compresión:</strong> 150-200 MPa
                </li>
                <li>
                  • <strong>Resistencia térmica:</strong> ⚠️ LIMITADA - Hasta 80-100°C
                  (las resinas se dañan con calor directo)
                </li>
                <li>
                  • <strong>Resistencia a ácidos/manchas:</strong> ✓ EXCELENTE (superficie
                  no porosa)
                </li>
                <li>
                  • <strong>Uniformidad:</strong> ✓ Color y patrón consistentes (producto
                  industrial)
                </li>
              </ul>
            </div>

            <div>
              <h4 class="font-bold text-gray-900 mb-3 flex items-center gap-2">
                <span class="text-blue-600">📋</span> Cobertura de Garantía
              </h4>
              <ul class="space-y-2 text-sm text-gray-700">
                <li>
                  ✓ Defectos de fabricación (burbujas, delaminación,
                  inclusiones)
                </li>
                <li>✓ Fisuras por defectos estructurales del material</li>
                <li class="text-red-600 font-semibold">
                  ✗ Pérdida de brillo por uso, desgaste o limpieza
                </li>
                <li class="text-red-600 font-semibold">
                  ✗ Daños por calor directo (sartenes, ollas, planchas a >100°C)
                </li>
                <li class="text-red-600 font-semibold">
                  ✗ Quemaduras o decoloración por resinas dañadas térmicamente
                </li>
                <li class="text-red-600 font-semibold">
                  ✗ Grietas por impactos contundentes
                </li>
                <li class="text-red-600 font-semibold">
                  ✗ Rayones profundos por objetos metálicos afilados
                </li>
              </ul>
            </div>
          </div>

          <div class="mt-6 bg-red-50 border border-red-300 rounded-lg p-4">
            <p class="text-sm text-red-800">
              <strong>⚠️ CRÍTICO - Sensibilidad al Calor:</strong> El cuarzo ingenieril
              NO debe exponerse a calor directo. Siempre use protectores térmicos
              para ollas, sartenes o electrodomésticos calientes. Las resinas poliméricas
              pueden quemarse, decolorarse o agrietarse a temperaturas superiores
              a 100°C. Este daño NO está cubierto por garantía.
            </p>
          </div>
        </div>

        <!-- Piedra Sinterizada (Neolith, Dekton, etc.) -->
        <div
          class="bg-white rounded-2xl shadow-lg p-8 mb-8 border-t-4 border-blue-600"
        >
          <div class="flex items-start gap-4 mb-6">
            <div class="text-4xl">🔥</div>
            <div class="flex-1">
              <h3 class="text-2xl font-bold text-gray-900 mb-2">
                Piedra Sinterizada (Porcelánico Ultra-compactado)
              </h3>
              <p class="text-sm text-gray-500 uppercase tracking-wide">
                Garantía del Fabricante: 10-25 años | Material de Máximo
                Desempeño
              </p>
            </div>
          </div>

          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <h4 class="font-bold text-gray-900 mb-3 flex items-center gap-2">
                <span class="text-green-600">✓</span> Características Técnicas
              </h4>
              <ul class="space-y-2 text-sm text-gray-700">
                <li>
                  • <strong>Composición:</strong> Minerales naturales (cuarzo, porcelana,
                  feldespato, sílice, óxidos metálicos) sinterizados
                </li>
                <li>
                  • <strong>Proceso de fabricación:</strong> 25,000 toneladas de presión
                  + 1,200°C (tecnología Sinterización Partículas)
                </li>
                <li>
                  • <strong>Dureza Mohs:</strong> 7-8 (Similar al cuarzo natural,
                  superior a granito)
                </li>
                <li>• <strong>Densidad:</strong> 2.4-2.5 g/cm³</li>
                <li>
                  • <strong>Absorción de agua:</strong> &lt;0.01% (PRÁCTICAMENTE CERO
                  - Superficie ultra-compacta)
                </li>
                <li>
