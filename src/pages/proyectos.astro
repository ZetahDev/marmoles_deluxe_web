---
import Layout from "../layouts/Layout.astro";
import SEOSchemaData from "../components/SEOSchemaData.tsx";
import MasonryGallery from "../components/MasonryGallery"; // New Client Component
import GeoTrustSection from "../components/GeoTrustSection.astro";
import { cloudinaryAssets } from "../lib/images/cloudinaryAssets";
import { buildSeoImageUrl } from "../lib/images/cloudinary";

const title =
  "Galería de Proyectos - Mármoles Deluxe | Inspiración en Gran Formato";
const description =
  "Explora nuestra galería de proyectos y diseños realizados con mármol, granito y piedra sinterizada. Inspírate para tu próxima obra con Mármoles Deluxe.";

const keywords =
  "galería mármol, fotos proyectos granito, diseño interiores cocina, baños lujo, encimeras cali, inspiración piedra sinterizada";

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const pageUrl = canonicalURL.toString();
const metaImage = buildSeoImageUrl(cloudinaryAssets.seo.projects);
---

<Layout title={title} description={description}>
  <Fragment slot="head">
    <!-- SEO Meta Tags -->
    <meta name="keywords" content={keywords} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={metaImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={metaImage} />

    <!-- Geo Tags -->
    <meta name="geo.region" content="CO-VAC" />
    <meta name="geo.placename" content="Cali" />
  </Fragment>

  <SEOSchemaData
    pageTitle={title}
    pageDescription={description}
    pageUrl={pageUrl}
    pageImage={metaImage}
  />

  <main class="pt-24 pb-16 min-h-screen bg-gray-50">
    <!-- Header -->
    <section class="container mx-auto px-4 mb-12 text-center">
      <h1
        class="text-4xl md:text-5xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-marmoles-gold to-marmoles-black mb-4"
      >
        Galería de Inspiración
      </h1>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">
        Descubre cómo nuestros materiales transforman espacios. Una colección
        curada de texturas y diseños aplicados.
      </p>
    </section>

    <!-- Client-Side Masonry Gallery with Progressive Loading -->
    <MasonryGallery client:load />

    <div class="container mx-auto px-4 mt-16">
      <GeoTrustSection
        title="La galería inspira; los casos de estudio explican"
        answer="La galería sigue siendo útil para explorar estilos y texturas, pero si quieres reforzar autoridad SEO y GEO necesitas narrativa de proyecto. Por eso ahora el sitio también cuenta con una vista dedicada donde cada intervención puede documentar material, tiempos, alcance y resultado."
        bullets={[
          "Usa la galería para inspiración visual rápida.",
          "Usa casos de estudio para documentar experiencia real y decisiones técnicas.",
          "Combinar ambas superficies mejora comprensión humana y de buscadores.",
        ]}
      />
      <div class="mt-8 text-center">
        <a
          href="/casos-de-estudio"
          class="inline-flex items-center justify-center rounded-full bg-marmoles-black px-6 py-3 font-semibold text-white hover:bg-marmoles-gold hover:text-marmoles-black transition-colors"
        >
          Ir a casos de estudio
        </a>
      </div>
      <div class="mt-8 rounded-2xl border border-gray-200 bg-white p-6 text-center">
        <h2 class="text-2xl font-bold text-marmoles-black mb-3">
          Rutas por marca en piedra sinterizada
        </h2>
        <p class="text-gray-700 mb-4">
          Explora páginas dedicadas para especificar material según uso y estilo del proyecto.
        </p>
        <div class="flex flex-wrap justify-center gap-3 text-sm">
          <a href="/piedra-sinterizada/altea" class="text-marmoles-gold font-semibold hover:underline">Altea</a>
          <a href="/piedra-sinterizada/terracina" class="text-marmoles-gold font-semibold hover:underline">Terracina</a>
          <a href="/piedra-sinterizada/dekton" class="text-marmoles-gold font-semibold hover:underline">Dekton</a>
          <a href="/piedra-sinterizada/neolith" class="text-marmoles-gold font-semibold hover:underline">Neolith</a>
          <a href="/piedra-sinterizada/silestone" class="text-marmoles-gold font-semibold hover:underline">Silestone</a>
          <a href="/piedra-sinterizada/artemarmol" class="text-marmoles-gold font-semibold hover:underline">Artemarmol</a>
        </div>
      </div>
      <div class="mt-8 rounded-2xl border border-gray-200 bg-white p-6">
        <h2 class="text-2xl font-bold text-marmoles-black mb-3">
          Rutas comerciales más consultadas
        </h2>
        <p class="text-gray-700 mb-4">
          Para cotizar más rápido según intención de compra, revisa estas páginas clave:
        </p>
        <div class="flex flex-wrap gap-3 text-sm">
          <a href="/mesones-de-cocina" class="text-marmoles-gold font-semibold hover:underline">Mesones de cocina en Cali</a>
          <a href="/precios" class="text-marmoles-gold font-semibold hover:underline">Precios de mesones de cocina</a>
          <a href="/blanco-polar" class="text-marmoles-gold font-semibold hover:underline">Cuarzo Blanco Polar Quartzstone</a>
        </div>
      </div>
    </div>
  </main>
</Layout>
