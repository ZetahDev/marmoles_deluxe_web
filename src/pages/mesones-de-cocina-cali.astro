---
import LocalSeoLanding from "../components/LocalSeoLanding.astro";

const faqs = [
  {
    question: "¿Cuánto tarda la instalación de un mesón de cocina en Cali?",
    answer:
      "Dependiendo de medidas y material, la mayoría de proyectos residenciales se ejecutan entre 4 y 7 días hábiles desde la confirmación técnica.",
  },
  {
    question: "¿Qué materiales recomiendan para alto uso diario?",
    answer:
      "Para cocina residencial de alto tráfico recomendamos cuarzo y piedra sinterizada por su baja porosidad, estabilidad y mantenimiento simple.",
  },
  {
    question: "¿Incluyen visita técnica y toma de medidas?",
    answer:
      "Sí. La visita técnica permite validar medidas, tipo de borde, salpicadero y detalles de instalación antes de cotizar en firme.",
  },
];
---

<LocalSeoLanding
  seo={{
    title: "Mesones de Cocina en Cali | Mármoles Deluxe",
    description:
      "Diseño, suministro e instalación de mesones de cocina en Cali. Cuarzo, granito y piedra sinterizada con ejecución técnica y tiempos claros.",
    canonical: "/mesones-de-cocina-cali",
    primaryKeyword: "mesones de cocina cali, encimeras de cocina cali",
    localArea: "Cali",
    schemaType: "Service",
    faq: faqs,
  }}
  h1="Mesones de Cocina en Cali con Instalación Técnica y Acabado Premium"
  heroIntro="Atendemos proyectos residenciales y comerciales en Cali con materiales de alto desempeño, fabricación precisa y una ruta de instalación diseñada para minimizar reprocesos."
  bodyText={`Nuestro servicio combina asesoría, selección de material, toma de medidas, fabricación y montaje final. Trabajamos cuarzo, granito, mármol y piedra sinterizada con enfoque en durabilidad, estética y limpieza en obra.

El proceso se ejecuta con checklist técnico para plomería, nivelación, soportes y uniones, para evitar improvisaciones que afectan tiempos y acabados. También coordinamos mantenimiento inicial y recomendaciones por tipo de superficie.`}
  trustTitle="Qué hace confiable esta propuesta en Cali"
  trustAnswer="La propuesta se construye sobre ejecución técnica, tiempos definidos y acompañamiento antes y después de instalación. La prioridad es que la cotización sea clara y el resultado final se corresponda con lo prometido."
  trustBullets={[
    "Visita técnica con validación real de medidas y puntos críticos.",
    "Materiales con enfoque en resistencia, estética y mantenimiento.",
    "Soporte postinstalación y recomendaciones de cuidado.",
  ]}
  faqs={faqs}
  ctaHref="https://wa.me/573132592793?text=Hola%2C%20quiero%20cotizar%20un%20mes%C3%B3n%20de%20cocina%20en%20Cali."
  ctaLabel="Cotizar por WhatsApp"
  secondaryHref="/contactanos"
  secondaryLabel="Agendar visita técnica"
/>
