---
import LocalSeoLanding from "../components/LocalSeoLanding.astro";

const faqs = [
  {
    question: "¿Realizan instalación de mesones en Palmira?",
    answer:
      "Sí. Atendemos Palmira con agenda programada para proyectos residenciales y comerciales de cocina y baño.",
  },
  {
    question: "¿Puedo cotizar granito y cuarzo en la misma propuesta?",
    answer:
      "Sí. Podemos comparar opciones en una misma cotización para decidir por durabilidad, estética y presupuesto.",
  },
  {
    question: "¿Incluyen perforaciones para estufa y lavaplatos?",
    answer:
      "Sí, las perforaciones se definen en visita técnica y quedan incluidas en el alcance aprobado.",
  },
];
---

<LocalSeoLanding
  seo={{
    title: "Mesones de Cocina en Palmira | Mármoles Deluxe",
    description:
      "Suministro e instalación de mesones de cocina en Palmira con cuarzo, granito y piedra sinterizada. Proyecto técnico de principio a fin.",
    canonical: "/mesones-de-cocina-palmira",
    primaryKeyword: "mesones de cocina palmira, marmolistas palmira",
    localArea: "Palmira",
    schemaType: "Service",
    faq: faqs,
  }}
  h1="Mesones de Cocina en Palmira con Criterio Técnico y Estético"
  heroIntro="Ejecutamos proyectos de superficies en Palmira con metodología clara: diagnóstico técnico, selección de material, fabricación y montaje final con foco en calidad."
  bodyText={`Trabajamos proyectos donde el cliente necesita una propuesta confiable para cocina: medidas exactas, materiales adecuados y una instalación limpia. Cubrimos cuarzo, granito y superficies sinterizadas con acompañamiento durante toda la ejecución.

La visita técnica define el alcance real y permite construir una cotización sin vacíos. De esta manera se controla el presupuesto y se mejora la previsibilidad del proyecto completo.`}
  trustTitle="Cómo aseguramos consistencia en Palmira"
  trustAnswer="El diferencial está en alinear diseño, fabricación e instalación desde el inicio. Con esa coordinación se reducen ajustes en obra y se mejora la durabilidad del resultado."
  trustBullets={[
    "Evaluación técnica previa con recomendaciones accionables.",
    "Cotización por alcance real, no por estimaciones ambiguas.",
    "Seguimiento de instalación y cierre con checklist de entrega.",
  ]}
  faqs={faqs}
  ctaHref="https://wa.me/573132592793?text=Hola%2C%20quiero%20cotizar%20un%20mes%C3%B3n%20de%20cocina%20en%20Palmira."
  ctaLabel="Cotizar en Palmira"
  secondaryHref="/contactanos"
  secondaryLabel="Solicitar asesoría"
/>
