---
import { Image } from "astro:assets";
import { caseStudies } from "../../data/caseStudies";
import { cloudinaryAssets } from "../../lib/images/cloudinaryAssets";

const webhookUrl = import.meta.env.PUBLIC_ESTUDIO_WEBHOOK_URL || "";
const gtmId = import.meta.env.PUBLIC_GTM_ID || "";
const ga4Id = import.meta.env.PUBLIC_GA4_ID || "";

const canonicalUrl = "https://estudio.marmolesdeluxe.com/";
const whatsappNumber = "573186110790";
const brandLogo = cloudinaryAssets.branding.logoMain;
const whatsappIconPath =
  "M16 3.2A12.6 12.6 0 0 0 5.1 22.1L3.6 28.8l6.8-1.6A12.6 12.6 0 1 0 16 3.2Zm0 2.4a10.2 10.2 0 1 1-5 19.1l-.4-.2-3.7.9.8-3.7-.3-.4A10.2 10.2 0 0 1 16 5.6Zm-4.3 5.2c-.3 0-.8.1-1.2.6-.4.4-1.5 1.5-1.5 3.6s1.6 4.2 1.8 4.5c.2.3 3.1 4.9 7.7 6.5 3.8 1.3 4.6.7 5.4.7.8-.1 2.7-1.1 3.1-2.2.4-1.1.4-2 .3-2.2-.1-.2-.4-.3-.9-.6l-2.9-1.4c-.4-.2-.8-.2-1.1.3-.3.5-1.2 1.4-1.5 1.7-.3.3-.6.3-1 .1-.5-.2-2-.7-3.7-2.3-1.4-1.2-2.3-2.8-2.6-3.2-.3-.5 0-.7.2-1l.8-.9c.3-.3.4-.5.6-.9.2-.3.1-.6 0-.9l-1.3-3c-.3-.7-.7-.7-1-.7h-1.2Z";
const campaignParams =
  "utm_source=google_ads&utm_medium=cpc&utm_campaign=studio_marmoles_deluxe&utm_content=hero_whatsapp_cta";
const whatsappMessage =
  "Deseo agendar un diagnóstico técnico para un proyecto premium de cocina, mesón de mármol o piedra sinterizada en Cali.";
const whatsappUrl = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(whatsappMessage)}&${campaignParams}`;

const title =
  "Studio Mármoles Deluxe Cali | Cocinas Premium, Mármol y Piedra Sinterizada";
const description =
  "Agenda un diagnóstico técnico con Studio Mármoles Deluxe en Cali. Diseñamos, modulamos e instalamos mesones de mármol, piedra sinterizada y superficies premium para hogares, arquitectos y constructoras.";
const keywords =
  "studio mármoles deluxe, cocinas premium Cali, mesones de mármol Cali, piedra sinterizada Cali, trabajo en mármol Cali, superficies premium, arquitectos Cali, constructoras Cali, mármol para cocinas";

const heroImage = cloudinaryAssets.home.hero;
const processImages = [
  cloudinaryAssets.home.projectRoyalWhite,
  cloudinaryAssets.home.projectBlackDiamond,
  cloudinaryAssets.home.projectIslaInfinity,
];
const caseVisuals = [
  cloudinaryAssets.home.projectRoyalWhite,
  cloudinaryAssets.home.projectBlackDiamond,
  cloudinaryAssets.home.projectLobbyMajestic,
];
const b2bImage = cloudinaryAssets.home.projectBlackDiamond;

const studioOffer = [
  {
    title: "Diagnóstico técnico inicial",
    text: "Revisamos uso, medidas, mueble base, estilo y complejidad antes de hablar de precio.",
  },
  {
    title: "Selección de material",
    text: "Te guiamos entre mármol, cuarzo, granito y piedra sinterizada según estética, mantenimiento y presupuesto.",
  },
  {
    title: "Modulación y cortes",
    text: "Definimos juntas, vetas, cantos, salpicadero y perforaciones para evitar improvisaciones en obra.",
  },
  {
    title: "Cotización accionable",
    text: "Recibes una ruta clara de alcance, tiempos y próximos pasos para ejecutar sin sorpresas.",
  },
];

const proofStats = [
  { value: "16+", label: "años en superficies" },
  { value: "5 días", label: "ejecución típica controlada" },
  { value: "Cali", label: "cobertura local y B2B" },
];

const processSteps = [
  {
    number: "01",
    title: "Levantamiento",
    text: "Medimos, validamos soportes, ubicación de equipos, lavaplatos, grifería, cantos y accesos de instalación.",
  },
  {
    number: "02",
    title: "Especificación",
    text: "Seleccionamos material, acabado y despiece para que la superficie se vea diseñada, no simplemente instalada.",
  },
  {
    number: "03",
    title: "Fabricación",
    text: "Cortes, pulidos, perforaciones y control de calidad se preparan antes de llevar piezas a obra.",
  },
  {
    number: "04",
    title: "Instalación",
    text: "Equipo especializado instala, remata, limpia y entrega recomendaciones de uso y mantenimiento.",
  },
];

const studioCases = caseStudies.slice(0, 3).map((study, index) => ({
  ...study,
  studioImage: caseVisuals[index],
}));

const b2bItems = [
  "Asesoría técnica desde etapa de diseño",
  "Muestras y moodboards personalizados",
  "Despieces, cortes y documentación técnica",
  "Logística, fabricación e instalación profesional",
];

const trustItems = [
  "Atención local en Cali y Valle del Cauca.",
  "Portafolio, casos de estudio y evidencia visual del proceso.",
  "Materiales de marcas reconocidas y selección según uso real.",
  "Acompañamiento para hogares, arquitectos, diseñadores y constructoras.",
];

const studioFaqs = [
  {
    question: "¿El diagnóstico técnico tiene costo?",
    answer:
      "La orientación inicial por WhatsApp no tiene costo. Cuando el proyecto requiere visita, medición o levantamiento avanzado, el equipo confirma alcance, disponibilidad y condiciones antes de agendar.",
  },
  {
    question: "¿Trabajan solo cocinas premium?",
    answer:
      "No. Studio Mármoles Deluxe atiende cocinas, barras, baños, lobbies, recepciones y proyectos B2B donde la superficie tenga alto impacto visual o exigencia técnica.",
  },
  {
    question: "¿Qué materiales especifican?",
    answer:
      "Trabajamos mármol, granito, cuarzo y piedra sinterizada. La recomendación depende del uso, exposición al calor, mantenimiento esperado, formato, estilo y presupuesto.",
  },
  {
    question: "¿Atienden arquitectos y constructoras?",
    answer:
      "Sí. La unidad B2B apoya especificación, muestras, moodboards, despieces, logística e instalación para proyectos residenciales, comerciales y de alto formato.",
  },
];

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": ["LocalBusiness", "ProfessionalService"],
      "@id": `${canonicalUrl}#business`,
      name: "Studio Mármoles Deluxe",
      alternateName: "Estudio Mármoles Deluxe",
      url: canonicalUrl,
      image: heroImage,
      telephone: "+57 318 611 0790",
      priceRange: "$$$",
      address: {
        "@type": "PostalAddress",
        streetAddress: "Cra 5 Norte 40-43, barrio El Popular",
        addressLocality: "Cali",
        addressRegion: "Valle del Cauca",
        addressCountry: "CO",
      },
      geo: {
        "@type": "GeoCoordinates",
        latitude: 3.4516,
        longitude: -76.532,
      },
      areaServed: ["Cali", "Valle del Cauca", "Colombia"],
      sameAs: [
        "https://www.instagram.com/marmolesdeluxe/",
        "https://www.facebook.com/Marmolesdeluxe",
      ],
      contactPoint: {
        "@type": "ContactPoint",
        telephone: "+57 318 611 0790",
        contactType: "sales",
        areaServed: "CO",
        availableLanguage: ["es"],
      },
      hasOfferCatalog: {
        "@type": "OfferCatalog",
        name: "Servicios Studio Mármoles Deluxe",
        itemListElement: [
          {
            "@type": "Offer",
            itemOffered: {
              "@type": "Service",
              name: "Diagnóstico técnico para cocinas premium",
              areaServed: "Cali",
            },
          },
          {
            "@type": "Offer",
            itemOffered: {
              "@type": "Service",
              name: "Mesones de mármol y superficies premium",
              areaServed: "Cali",
            },
          },
          {
            "@type": "Offer",
            itemOffered: {
              "@type": "Service",
              name: "Especificación de piedra sinterizada para proyectos B2B",
              areaServed: "Valle del Cauca",
            },
          },
        ],
      },
    },
    {
      "@type": "WebPage",
      "@id": `${canonicalUrl}#webpage`,
      url: canonicalUrl,
      name: title,
      description,
      inLanguage: "es-CO",
      primaryImageOfPage: heroImage,
      about: { "@id": `${canonicalUrl}#business` },
      potentialAction: {
        "@type": "ContactAction",
        target: whatsappUrl,
        name: "Agendar diagnóstico técnico por WhatsApp",
      },
    },
    {
      "@type": "FAQPage",
      "@id": `${canonicalUrl}#faq`,
      mainEntity: studioFaqs.map((faq) => ({
        "@type": "Question",
        name: faq.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: faq.answer,
        },
      })),
    },
  ],
};
---

<!doctype html>
<html lang="es-CO">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <meta name="geo.region" content="CO-VAC" />
    <meta name="geo.placename" content="Cali" />
    <meta name="geo.position" content="3.4516;-76.5320" />
    <meta name="ICBM" content="3.4516, -76.5320" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Studio Mármoles Deluxe" />
    <meta property="og:locale" content="es_CO" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={heroImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={heroImage} />
    <link rel="preconnect" href="https://res.cloudinary.com" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Manrope:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    {
      gtmId && (
        <script is:inline>
          {`(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','${gtmId}');`}
        </script>
      )
    }
    {
      ga4Id && (
        <>
          <script async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`} />
          <script is:inline>
            {`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${ga4Id}',{anonymize_ip:true});`}
          </script>
        </>
      )
    }
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  </head>

  <body>
    {
      gtmId && (
        <noscript>
          <iframe
            src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`}
            height="0"
            width="0"
            style="display:none;visibility:hidden"
          />
        </noscript>
      )
    }

    <header class="studio-header" aria-label="Navegación de Studio Mármoles Deluxe">
      <a class="brand" href="#inicio" aria-label="Ir al inicio">
        <img
          src={brandLogo}
          alt="Mármoles Deluxe"
          class="brand-logo"
          width="180"
          height="48"
          decoding="async"
          fetchpriority="high"
        />
        <span class="brand-copy">Studio <strong>Superficies Premium</strong></span>
      </a>
      <nav aria-label="Navegación interna">
        <a href="#diagnostico">Diagnóstico</a>
        <a href="#casos">Casos</a>
        <a href="#b2b">B2B</a>
        <a class="nav-cta track-cta" href={whatsappUrl} target="_blank" rel="noopener noreferrer" data-cta="nav_whatsapp">
          WhatsApp
        </a>
      </nav>
    </header>

    <main id="inicio">
      <section class="hero" aria-labelledby="hero-title">
        <div class="hero-image" aria-hidden="true">
          <Image
            src={heroImage}
            alt=""
            width={1800}
            height={1200}
            format="webp"
            sizes="100vw"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
        </div>
        <div class="hero-shell">
          <div class="hero-copy">
            <p class="hero-materials">Studio técnico de superficies premium en Cali</p>
            <h1 id="hero-title">Cocinas y mesones premium, diseñados para verse impecables.</h1>
            <p class="hero-summary">
              Diagnóstico, selección de material, modulación, fabricación e instalación para proyectos en mármol, cuarzo y piedra sinterizada.
            </p>
            <div class="hero-actions" aria-label="Acciones principales">
              <a class="whatsapp-button track-cta" href={whatsappUrl} target="_blank" rel="noopener noreferrer" data-cta="hero_whatsapp">
                <span class="whatsapp-symbol" aria-hidden="true">
                  <svg viewBox="0 0 32 32" role="img"><path d={whatsappIconPath} /></svg>
                </span>
                Agendar diagnóstico
              </a>
              <a class="case-anchor" href="#casos">Ver casos reales</a>
            </div>
          </div>

          <aside class="diagnostic-card" aria-label="Oferta de diagnóstico técnico">
            <p class="card-label">Para pauta y agenda prioritaria</p>
            <h2>Diagnóstico técnico inicial</h2>
            <p>
              Envíanos fotos, medidas aproximadas y tipo de proyecto. Te respondemos con una ruta clara de material, alcance y siguiente paso.
            </p>
            <div class="card-checks">
              <span>Respuesta ágil</span>
              <span>Asesoría en Cali</span>
              <span>Hogares y B2B</span>
            </div>
            <a class="card-link track-cta" href="#contacto" data-cta="hero_form_anchor">Completar formulario</a>
          </aside>
        </div>
      </section>

      <section class="proof-strip" aria-label="Pruebas de confianza Studio">
        {
          proofStats.map((stat) => (
            <article>
              <strong>{stat.value}</strong>
              <span>{stat.label}</span>
            </article>
          ))
        }
      </section>

      <section class="offer-section" id="diagnostico" aria-labelledby="offer-title">
        <div class="section-kicker">Antes de cotizar</div>
        <div class="offer-heading">
          <h2 id="offer-title">Una superficie premium no se improvisa.</h2>
          <p>
            La diferencia entre una instalación común y un resultado de alto valor está en lo que se decide antes de cortar la primera pieza.
          </p>
        </div>
        <div class="offer-grid">
          {
            studioOffer.map((item, index) => (
              <article>
                <span>{String(index + 1).padStart(2, "0")}</span>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="process-section" id="proceso" aria-labelledby="process-title">
        <div class="process-intro">
          <p class="section-label">Proceso Studio</p>
          <h2 id="process-title">Control técnico para acabados que sí se sienten premium.</h2>
          <p>
            Unimos diseño, selección de piedra, fabricación y montaje para que el proyecto conserve intención estética y precisión constructiva.
          </p>
        </div>
        <div class="process-flow">
          <ol class="process-list">
            {
              processSteps.map((step) => (
                <li>
                  <span>{step.number}</span>
                  <article>
                    <h3>{step.title}</h3>
                    <p>{step.text}</p>
                  </article>
                </li>
              ))
            }
          </ol>
          <div class="process-gallery" aria-label="Imágenes del proceso técnico">
            {
              processImages.map((image, index) => (
                <figure>
                  <Image
                    src={image}
                    alt={`Referencia visual de proceso técnico Studio Mármoles Deluxe ${index + 1}`}
                    width={520}
                    height={340}
                    format="webp"
                    sizes="(max-width: 760px) 31vw, 24vw"
                    loading="lazy"
                    decoding="async"
                  />
                </figure>
              ))
            }
          </div>
        </div>
      </section>

      <section class="cases-section" id="casos" aria-labelledby="cases-title">
        <div class="section-heading">
          <div>
            <p class="section-label">Casos reales</p>
            <h2 id="cases-title">Evidencia concreta antes de tomar una decisión.</h2>
          </div>
          <a class="outline-link track-cta" href={whatsappUrl} target="_blank" rel="noopener noreferrer" data-cta="cases_whatsapp">Pedir asesoría</a>
        </div>
        <div class="case-grid" aria-label="Casos reales de superficies premium">
          {
            studioCases.map((study) => (
              <article class="case-card">
                <figure>
                  <Image
                    src={study.studioImage}
                    alt={`Caso real ${study.title}`}
                    width={720}
                    height={520}
                    format="webp"
                    sizes="(max-width: 760px) 100vw, 31vw"
                    loading="lazy"
                    decoding="async"
                  />
                </figure>
                <div>
                  <p>{study.location} · {study.timelineLabel}</p>
                  <h3>{study.title}</h3>
                  <dl>
                    <div>
                      <dt>Material</dt>
                      <dd>{study.materialBrand} · {study.materialReference}</dd>
                    </div>
                    <div>
                      <dt>Aplicación</dt>
                      <dd>{study.application}</dd>
                    </div>
                    <div>
                      <dt>Resultado</dt>
                      <dd>{study.result}</dd>
                    </div>
                  </dl>
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <section class="b2b-section" id="b2b" aria-labelledby="b2b-title">
        <figure class="b2b-image">
          <Image
            src={b2bImage}
            alt="Superficies premium para arquitectos, constructoras y diseñadores en Cali"
            width={980}
            height={820}
            format="webp"
            sizes="(max-width: 760px) 100vw, 50vw"
            loading="lazy"
            decoding="async"
          />
        </figure>
        <div class="b2b-content">
          <p class="section-label">Unidad B2B</p>
          <h2 id="b2b-title">Aliados para arquitectos, diseñadores y constructoras.</h2>
          <p>
            Acompañamos proyectos donde la superficie define la percepción del espacio: cocinas de autor, barras, baños, lobbies y recepciones.
          </p>
          <ul aria-label="Servicios B2B">
            {
              b2bItems.map((item) => (
                <li>
                  <span aria-hidden="true"></span>
                  {item}
                </li>
              ))
            }
          </ul>
          <a class="b2b-cta track-cta" href="#contacto" data-cta="b2b_form_anchor">Hablar con Studio B2B</a>
        </div>
      </section>

      <section class="trust-section" aria-labelledby="trust-title">
        <div>
          <p class="section-label">Señales reales de confianza</p>
          <h2 id="trust-title">Una operación local detrás de cada superficie.</h2>
        </div>
        <div class="trust-grid">
          {
            trustItems.map((item) => (
              <article>
                <span aria-hidden="true">✓</span>
                <p>{item}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="contact-section" id="contacto" aria-labelledby="contact-title">
        <div class="contact-copy">
          <p class="section-label">Agenda Studio</p>
          <h2 id="contact-title">Cuéntanos tu proyecto y te damos una ruta clara.</h2>
          <p>
            Completa el formulario o escribe por WhatsApp. La conversación inicia con fotos, medidas aproximadas y el tipo de superficie que estás considerando.
          </p>
          <div class="contact-note">
            <strong>Respuesta en menos de 2 horas hábiles</strong>
            <span>Atención para Cali, Valle del Cauca y proyectos B2B.</span>
          </div>
        </div>
        <form class="lead-form" id="premium-lead-form">
          <div class="form-row">
            <label>
              <span>Nombre completo</span>
              <input name="nombre" type="text" autocomplete="name" placeholder="Tu nombre" required />
            </label>
            <label>
              <span>WhatsApp</span>
              <input name="telefono" type="tel" inputmode="tel" autocomplete="tel" placeholder="+57..." required />
            </label>
          </div>
          <div class="form-row">
            <label>
              <span>Tipo de proyecto</span>
              <select name="tipoProyecto" required>
                <option value="">Selecciona una opción</option>
                <option value="Cocina premium residencial">Cocina premium residencial</option>
                <option value="Mesón de mármol o cuarzo">Mesón de mármol o cuarzo</option>
                <option value="Piedra sinterizada gran formato">Piedra sinterizada gran formato</option>
                <option value="Proyecto B2B">Proyecto B2B</option>
              </select>
            </label>
            <label>
              <span>Etapa</span>
              <select name="etapa" required>
                <option value="">Selecciona</option>
                <option value="Idea inicial">Idea inicial</option>
                <option value="Con medidas aproximadas">Con medidas aproximadas</option>
                <option value="Con planos o diseño">Con planos o diseño</option>
                <option value="Listo para cotizar">Listo para cotizar</option>
              </select>
            </label>
          </div>
          <label>
            <span>Cuéntanos qué quieres lograr</span>
            <textarea name="detalle" rows="4" placeholder="Ej: cocina con isla, mesón en mármol claro, proyecto para apartamento en Cali..." required></textarea>
          </label>
          <aside class="response-box" aria-label="Condiciones de atención">
            <p>Sin compromiso comercial inicial.</p>
            <p>Recomendación de material según uso real.</p>
            <p>Ruta de alcance, tiempos y siguiente paso.</p>
          </aside>
          <button type="submit" class="whatsapp-button" data-cta="form_submit">
            <span class="whatsapp-symbol" aria-hidden="true">
              <svg viewBox="0 0 32 32" role="img"><path d={whatsappIconPath} /></svg>
            </span>
            Enviar y abrir WhatsApp
          </button>
          <p class="privacy-copy">Usaremos tus datos solo para responder esta solicitud comercial.</p>
        </form>
      </section>

      <section class="faq-section" id="faq" aria-labelledby="faq-title">
        <div class="section-heading">
          <div>
            <p class="section-label">Preguntas frecuentes</p>
            <h2 id="faq-title">Lo que conviene aclarar antes de invertir.</h2>
          </div>
        </div>
