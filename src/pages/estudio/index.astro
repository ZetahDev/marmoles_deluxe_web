---
import { Image } from "astro:assets";
import { caseStudies } from "../../data/caseStudies";
import { cloudinaryAssets } from "../../lib/images/cloudinaryAssets";

const webhookUrl = import.meta.env.PUBLIC_ESTUDIO_WEBHOOK_URL || "";
const gtmId = import.meta.env.PUBLIC_GTM_ID || "";
const ga4Id = import.meta.env.PUBLIC_GA4_ID || "";

const canonicalUrl = "https://estudio.marmolesdeluxe.com/";
const whatsappNumber = "573186110790";
const whatsappMessage =
  "Deseo cotizar una asesoría técnica para un proyecto de superficies premium con mármol, piedra sinterizada o mesones de mármol.";
const whatsappTracking =
  "utm_source=google_ads&utm_medium=cpc&utm_campaign=estudio_marmoles_deluxe&utm_content=whatsapp_cta";
const whatsappUrl = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(whatsappMessage)}&${whatsappTracking}`;

const title =
  "Estudio Mármoles Deluxe en Cali | Mesones de Mármol y Piedra Sinterizada";
const description =
  "Estudio especializado en superficies premium para cocinas de alta gama, trabajo en mármol, mesones de mármol y piedra sinterizada en Cali. Proyectos B2B para arquitectos y constructoras.";
const keywords =
  "piedra sinterizada Cali, mármol Cali, trabajo en mármol, mesones de mármol, superficies premium, cocinas de alta gama, proyectos B2B, arquitectos Cali, constructoras Cali, Mármoles Deluxe";

const heroImage = cloudinaryAssets.home.hero;
const processImages = [
  cloudinaryAssets.home.projectRoyalWhite,
  cloudinaryAssets.home.projectBlackDiamond,
  cloudinaryAssets.home.hero,
];
const caseImages = [
  cloudinaryAssets.home.projectRoyalWhite,
  cloudinaryAssets.home.projectBlackDiamond,
  cloudinaryAssets.home.hero,
];
const b2bImage = cloudinaryAssets.home.projectBlackDiamond;

const processSteps = [
  {
    number: "01",
    title: "Diagnóstico",
    text: "Analizamos el proyecto, el espacio y el material para definir la solución constructiva ideal.",
  },
  {
    number: "02",
    title: "Modulación",
    text: "Diseñamos cada pieza con modulación exacta para minimizar juntas y optimizar vetas.",
  },
  {
    number: "03",
    title: "Instalación controlada",
    text: "Montaje por especialistas, con equipos de precisión y protocolos que aseguran acabados impecables.",
  },
];

const cases = caseStudies.slice(0, 3).map((study, index) => ({
  image: caseImages[index],
  alt: `Caso real de ${study.application.toLowerCase()} en ${study.location}`,
  material:
    index === 0
      ? "Mármol Calacatta Oro"
      : index === 1
        ? "Cuarzo Taj Mahal Leather"
        : "Piedra sinterizada gran formato",
  challenge:
    index === 0
      ? "Isla monolítica con vetas continuas y cero juntas visibles."
      : index === 1
        ? "Uniformidad de tono y gran formato en áreas húmedas."
        : "Instalación exterior con cortes precisos y nivelación exacta.",
  time:
    index === 0 ? "18 días" : index === 1 ? "14 días" : "21 días",
  result:
    index === 0
      ? "Superficie escultórica y continuidad de veta en todas las caras."
      : index === 1
        ? "Acabado mate sedoso y máxima resistencia al uso diario."
        : "Superficie continua, antideslizante y de alto rendimiento.",
}));

const b2bItems = [
  {
    title: "Asesoría técnica desde diseño",
    icon: "M16 4l11 6v12l-11 6-11-6V10l11-6z M16 10v12 M7 11l9 5 9-5",
  },
  {
    title: "Muestras y moodboards personalizados",
    icon: "M7 7h18v18H7z M11 11h4v4h-4z M17 11h4v4h-4z M11 17h10v4H11z",
  },
  {
    title: "Documentación técnica y cortes detallados",
    icon: "M9 5h12l4 4v18H9z M21 5v5h5 M13 14h9 M13 19h9 M13 24h6",
  },
  {
    title: "Logística e instalación profesional",
    icon: "M5 12h16v9H5z M21 15h5l3 3v3h-8z M9 24a2 2 0 1 0 0-4 2 2 0 0 0 0 4z M24 24a2 2 0 1 0 0-4 2 2 0 0 0 0 4z",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "ProfessionalService"],
  name: "Estudio Mármoles Deluxe",
  url: canonicalUrl,
  image: heroImage,
  telephone: "+57 318 611 0790",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Cali",
    addressRegion: "Valle del Cauca",
    addressCountry: "CO",
  },
  areaServed: ["Cali", "Valle del Cauca", "Colombia"],
  description,
  makesOffer: [
    {
      "@type": "Offer",
      itemOffered: {
        "@type": "Service",
        name: "Trabajo en mármol y mesones de mármol para cocinas de alta gama",
      },
    },
    {
      "@type": "Offer",
      itemOffered: {
        "@type": "Service",
        name: "Especificación e instalación de piedra sinterizada para proyectos B2B",
      },
    },
  ],
};
---

<!doctype html>
<html lang="es-CO">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <meta name="geo.region" content="CO-VAC" />
    <meta name="geo.placename" content="Cali" />
    <meta name="geo.position" content="3.4516;-76.5320" />
    <meta name="ICBM" content="3.4516, -76.5320" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Estudio Mármoles Deluxe" />
    <meta property="og:locale" content="es_CO" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={heroImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={heroImage} />
    <link rel="preconnect" href="https://res.cloudinary.com" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Manrope:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    {
      gtmId && (
        <script is:inline>
          {`(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','${gtmId}');`}
        </script>
      )
    }
    {
      ga4Id && (
        <>
          <script async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}></script>
          <script is:inline>
            {`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${ga4Id}',{anonymize_ip:true});`}
          </script>
        </>
      )
    }
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>

  <body>
    {
      gtmId && (
        <noscript>
          <iframe
            src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`}
            height="0"
            width="0"
            style="display:none;visibility:hidden"
          />
        </noscript>
      )
    }

    <header class="studio-header" aria-label="Navegación de Estudio Mármoles Deluxe">
      <a class="brand" href="#inicio" aria-label="Ir al inicio">
        <span class="brand-mark">EMD</span>
        <span class="brand-copy">Estudio Mármoles <strong>Deluxe</strong></span>
      </a>
      <nav aria-label="Acciones internas">
        <a href="#casos">Casos</a>
        <a href="#b2b">B2B</a>
        <a class="nav-menu" href="#contacto" aria-label="Ir a WhatsApp y formulario">
          <span></span><span></span><span></span>
        </a>
      </nav>
    </header>

    <main id="inicio">
      <section class="hero" aria-labelledby="hero-title">
        <div class="hero-image" aria-hidden="true">
          <Image
            src={heroImage}
            alt=""
            width={1600}
            height={1800}
            format="webp"
            sizes="100vw"
            loading="eager"
            decoding="async"
          />
        </div>
        <div class="hero-panel">
          <p class="hero-materials">Piedra natural · Cuarzo · Piedra sinterizada</p>
          <h1 id="hero-title">Superficies de Alta Gama para Cocinas y Proyectos de Alto Valor</h1>
          <p class="hero-summary">
            Precisión técnica. Materiales excepcionales. Trabajo en mármol, mesones de mármol y superficies premium para proyectos en Cali.
          </p>
          <div class="hero-actions" aria-label="Acciones principales">
            <a class="whatsapp-button" href={whatsappUrl} target="_blank" rel="noopener noreferrer">
              <span class="whatsapp-symbol" aria-hidden="true">
                <svg viewBox="0 0 32 32" role="img"><path d="M16 3.2A12.6 12.6 0 0 0 5.1 22.1L3.6 28.8l6.8-1.6A12.6 12.6 0 1 0 16 3.2Zm0 2.4a10.2 10.2 0 1 1-5 19.1l-.4-.2-3.7.9.8-3.7-.3-.4A10.2 10.2 0 0 1 16 5.6Zm-4.3 5.2c-.3 0-.8.1-1.2.6-.4.4-1.5 1.5-1.5 3.6s1.6 4.2 1.8 4.5c.2.3 3.1 4.9 7.7 6.5 3.8 1.3 4.6.7 5.4.7.8-.1 2.7-1.1 3.1-2.2.4-1.1.4-2 .3-2.2-.1-.2-.4-.3-.9-.6l-2.9-1.4c-.4-.2-.8-.2-1.1.3-.3.5-1.2 1.4-1.5 1.7-.3.3-.6.3-1 .1-.5-.2-2-.7-3.7-2.3-1.4-1.2-2.3-2.8-2.6-3.2-.3-.5 0-.7.2-1l.8-.9c.3-.3.4-.5.6-.9.2-.3.1-.6 0-.9l-1.3-3c-.3-.7-.7-.7-1-.7h-1.2Z"/></svg>
              </span>
              Cotizar por WhatsApp
            </a>
            <a class="case-anchor" href="#casos">Ver casos reales</a>
          </div>
        </div>
        <aside class="hero-rating" aria-label="Calificación de servicio">
          <p>Estudio especializado en superficies premium</p>
          <div aria-label="Cinco de cinco estrellas">
            <span>★★★★★</span>
            <strong>5.0</strong>
          </div>
        </aside>
      </section>

      <section class="process-section" id="proceso" aria-labelledby="process-title">
        <div class="process-intro">
          <p class="section-label">Proceso EMD</p>
          <h2 id="process-title">Cambios técnicos que garantizan resultados perfectos.</h2>
          <p>
            Metodología propia aplicada en cada proyecto para asegurar precisión, estética y durabilidad en mármol, cuarzo y piedra sinterizada.
          </p>
        </div>
        <div class="process-flow">
          <ol class="process-list">
            {
              processSteps.map((step) => (
                <li>
                  <span>{step.number}</span>
                  <article>
                    <h3>{step.title}</h3>
                    <p>{step.text}</p>
                  </article>
                </li>
              ))
            }
          </ol>
          <div class="process-gallery" aria-label="Imágenes del proceso técnico">
            {
              processImages.map((image, index) => (
                <figure>
                  <Image
                    src={image}
                    alt={`Proceso técnico EMD para trabajo en mármol y superficies premium ${index + 1}`}
                    width={460}
                    height={290}
                    format="webp"
                    sizes="(max-width: 760px) 31vw, 24vw"
                    loading="lazy"
                    decoding="async"
                  />
                </figure>
              ))
            }
          </div>
        </div>
      </section>

      <section class="cases-section" id="casos" aria-labelledby="cases-title">
        <div class="section-heading">
          <div>
            <p class="section-label">Casos reales</p>
            <h2 id="cases-title">Proyectos que hablan por nosotros.</h2>
          </div>
          <a class="outline-link" href="#contacto">Ver más casos</a>
        </div>
        <div class="case-table" aria-label="Casos reales de superficies premium">
          {
            cases.map((item) => (
              <article class="case-row">
                <figure>
                  <Image
                    src={item.image}
                    alt={item.alt}
                    width={620}
                    height={310}
                    format="webp"
                    sizes="(max-width: 760px) 100vw, 34vw"
                    loading="lazy"
                    decoding="async"
                  />
                </figure>
                <dl>
                  <div>
                    <dt>Material</dt>
                    <dd>{item.material}</dd>
                  </div>
                  <div>
                    <dt>Reto</dt>
                    <dd>{item.challenge}</dd>
                  </div>
                  <div>
                    <dt>Tiempo real</dt>
                    <dd>{item.time}</dd>
                  </div>
                  <div>
                    <dt>Resultado</dt>
                    <dd>{item.result}</dd>
                  </div>
                </dl>
              </article>
            ))
          }
        </div>
      </section>

      <section class="b2b-section" id="b2b" aria-labelledby="b2b-title">
        <figure class="b2b-image">
          <Image
            src={b2bImage}
            alt="Materiales premium para arquitectos, constructoras y diseñadores"
            width={900}
            height={760}
            format="webp"
            sizes="(max-width: 760px) 100vw, 50vw"
            loading="lazy"
            decoding="async"
          />
        </figure>
        <div class="b2b-content">
          <p class="section-label">Unidad B2B</p>
          <h2 id="b2b-title">Aliados estratégicos para proyectos extraordinarios.</h2>
          <p>
            Acompañamos a arquitectos, constructoras y diseñadores en cada etapa del proyecto: selección de piedra sinterizada, trabajo en mármol, modulación, cortes e instalación.
          </p>
          <ul aria-label="Servicios B2B">
            {
              b2bItems.map((item) => (
                <li>
                  <svg viewBox="0 0 32 32" aria-hidden="true">
                    <path d={item.icon} />
                  </svg>
                  <span>{item.title}</span>
                </li>
              ))
            }
          </ul>
          <a class="b2b-cta" href="#contacto">Conocer Unidad B2B</a>
        </div>
      </section>

      <section class="contact-section" id="contacto" aria-labelledby="contact-title">
        <div class="contact-copy">
          <p class="section-label">Hablemos de tu proyecto</p>
          <h2 id="contact-title">Cuéntanos tu idea y te asesoramos hoy.</h2>
          <p>
            Agenda por WhatsApp una asesoría para cocinas de alta gama, mesones de mármol, piedra sinterizada o proyectos B2B en Cali.
          </p>
        </div>
        <form class="lead-form" id="premium-lead-form">
          <div class="form-row">
            <label>
              <span>Nombre completo</span>
              <input name="nombre" type="text" autocomplete="name" required />
            </label>
            <label>
              <span>WhatsApp</span>
              <input name="telefono" type="tel" inputmode="tel" autocomplete="tel" required />
            </label>
            <label>
              <span>Tipo de proyecto</span>
              <select name="tipoProyecto" required>
                <option value="">Selecciona</option>
                <option value="Remodelación Premium">Remodelación Premium</option>
                <option value="Obra Nueva de Diseñador">Obra Nueva de Diseñador</option>
                <option value="Proyecto B2B">Proyecto B2B</option>
              </select>
            </label>
          </div>
          <label>
            <span>Cuéntanos sobre tu proyecto</span>
            <textarea name="detalle" rows="4" required></textarea>
          </label>
          <aside class="response-box" aria-label="Condiciones de atención">
            <p>Respuesta en menos de 2 horas hábiles</p>
            <p>Asesoría técnica inicial</p>
            <p>Cotización detallada y sin compromiso</p>
          </aside>
          <button type="submit" class="whatsapp-button">
            <span class="whatsapp-symbol" aria-hidden="true">
              <svg viewBox="0 0 32 32" role="img"><path d="M16 3.2A12.6 12.6 0 0 0 5.1 22.1L3.6 28.8l6.8-1.6A12.6 12.6 0 1 0 16 3.2Zm0 2.4a10.2 10.2 0 1 1-5 19.1l-.4-.2-3.7.9.8-3.7-.3-.4A10.2 10.2 0 0 1 16 5.6Zm-4.3 5.2c-.3 0-.8.1-1.2.6-.4.4-1.5 1.5-1.5 3.6s1.6 4.2 1.8 4.5c.2.3 3.1 4.9 7.7 6.5 3.8 1.3 4.6.7 5.4.7.8-.1 2.7-1.1 3.1-2.2.4-1.1.4-2 .3-2.2-.1-.2-.4-.3-.9-.6l-2.9-1.4c-.4-.2-.8-.2-1.1.3-.3.5-1.2 1.4-1.5 1.7-.3.3-.6.3-1 .1-.5-.2-2-.7-3.7-2.3-1.4-1.2-2.3-2.8-2.6-3.2-.3-.5 0-.7.2-1l.8-.9c.3-.3.4-.5.6-.9.2-.3.1-.6 0-.9l-1.3-3c-.3-.7-.7-.7-1-.7h-1.2Z"/></svg>
            </span>
            Cotizar por WhatsApp
          </button>
        </form>
      </section>
    </main>

    <footer class="studio-footer">
      <strong>Estudio Mármoles Deluxe</strong>
      <span>Superficies de alta gama. Proyectos de alto valor.</span>
    </footer>

    <a class="floating-whatsapp" href={whatsappUrl} target="_blank" rel="noopener noreferrer" aria-label="Cotizar por WhatsApp">
      <svg viewBox="0 0 32 32" aria-hidden="true"><path d="M16 3.2A12.6 12.6 0 0 0 5.1 22.1L3.6 28.8l6.8-1.6A12.6 12.6 0 1 0 16 3.2Zm0 2.4a10.2 10.2 0 1 1-5 19.1l-.4-.2-3.7.9.8-3.7-.3-.4A10.2 10.2 0 0 1 16 5.6Zm-4.3 5.2c-.3 0-.8.1-1.2.6-.4.4-1.5 1.5-1.5 3.6s1.6 4.2 1.8 4.5c.2.3 3.1 4.9 7.7 6.5 3.8 1.3 4.6.7 5.4.7.8-.1 2.7-1.1 3.1-2.2.4-1.1.4-2 .3-2.2-.1-.2-.4-.3-.9-.6l-2.9-1.4c-.4-.2-.8-.2-1.1.3-.3.5-1.2 1.4-1.5 1.7-.3.3-.6.3-1 .1-.5-.2-2-.7-3.7-2.3-1.4-1.2-2.3-2.8-2.6-3.2-.3-.5 0-.7.2-1l.8-.9c.3-.3.4-.5.6-.9.2-.3.1-.6 0-.9l-1.3-3c-.3-.7-.7-.7-1-.7h-1.2Z"/></svg>
    </a>

    <script is:inline define:vars={{ webhookUrl, whatsappNumber }}>
      const form = document.getElementById("premium-lead-form");

      if (form) {
        form.addEventListener("submit", (event) => {
          event.preventDefault();

          const fd = new FormData(form);
          const nombre = String(fd.get("nombre") || "").trim();
          const telefono = String(fd.get("telefono") || "").trim();
          const tipoProyecto = String(fd.get("tipoProyecto") || "").trim();
          const detalle = String(fd.get("detalle") || "").trim();

          if (!nombre || !telefono || !tipoProyecto || !detalle) {
            form.reportValidity();
            return;
          }

          const payload = {
            nombre,
            telefono,
            tipoProyecto,
            detalle,
            source: "estudio.marmolesdeluxe.com",
            channel: "whatsapp",
            timestamp: new Date().toISOString(),
          };

          if (webhookUrl) {
            fetch(webhookUrl, {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify(payload),
              keepalive: true,
            }).catch(() => {});
          }

          const text = `Deseo cotizar una asesoría técnica para un proyecto de superficies premium. Mi nombre es ${nombre}. WhatsApp: ${telefono}. Tipo de proyecto: ${tipoProyecto}. Detalle: ${detalle}.`;
          window.location.href = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(text)}&utm_source=google_ads&utm_medium=cpc&utm_campaign=estudio_marmoles_deluxe&utm_content=form_submit`;
        });
      }
    </script>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --ink: #111111;
    --graphite: #171717;
    --paper: #f8f5ef;
    --paper-warm: #f1ece3;
    --muted: #655f56;
    --soft: rgba(17, 17, 17, 0.14);
    --gold: #b18a44;
    --gold-light: #d1ad68;
    --white: #fffaf2;
    --whatsapp: #31aa3e;
    --whatsapp-dark: #23872e;
    --max: 1240px;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
    background: var(--paper);
  }

  body {
    margin: 0;
    color: var(--ink);
    background: var(--paper);
    font-family: "Manrope", system-ui, sans-serif;
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
  }

  body::selection {
    background: var(--gold);
    color: #fff;
  }

  h1,
  h2,
  h3,
  p,
  dl,
  dd,
  figure {
    margin: 0;
  }

  h1,
  h2 {
    font-family: "Cormorant Garamond", Georgia, serif;
    font-weight: 600;
    letter-spacing: 0;
  }

  img,
  svg {
    display: block;
  }

  a {
    color: inherit;
  }

  .studio-header {
    position: absolute;
    inset: 0 0 auto;
    z-index: 40;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    width: 100%;
    padding: 1.05rem 1.1rem;
    color: #fff;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.68rem;
    max-width: 13rem;
    text-decoration: none;
  }

  .brand-mark {
    padding-right: 0.72rem;
    border-right: 1px solid rgba(255, 255, 255, 0.34);
    font-family: "Cormorant Garamond", Georgia, serif;
    font-size: 2.35rem;
