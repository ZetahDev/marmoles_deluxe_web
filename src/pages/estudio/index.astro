          {
            studioFaqs.map((faq) => (
              <article>
                <h3>{faq.question}</h3>
                <p>{faq.answer}</p>
              </article>
            ))
          }
        </div>
      </section>
    </main>

    <footer class="studio-footer">
      <strong>Studio Mármoles Deluxe</strong>
      <span>Cali, Valle del Cauca · Superficies premium para proyectos de alto valor.</span>
    </footer>

    <a class="floating-whatsapp track-cta" href={whatsappUrl} target="_blank" rel="noopener noreferrer" aria-label="Agendar diagnóstico por WhatsApp" data-cta="floating_whatsapp">
      <svg viewBox="0 0 32 32" aria-hidden="true"><path d={whatsappIconPath} /></svg>
    </a>

    <script is:inline define:vars={{ webhookUrl, whatsappNumber }}>
      const pushLeadEvent = (eventName, payload = {}) => {
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          event: eventName,
          page: "studio",
          ...payload,
        });
      };

      document.querySelectorAll(".track-cta").forEach((cta) => {
        cta.addEventListener("click", () => {
          pushLeadEvent("studio_cta_click", {
            cta: cta.getAttribute("data-cta") || "unknown",
          });
        });
      });

      const form = document.getElementById("premium-lead-form");

      if (form) {
        let formStarted = false;
        form.addEventListener("input", () => {
          if (formStarted) return;
          formStarted = true;
          pushLeadEvent("studio_form_start");
        });

        form.addEventListener("submit", (event) => {
          event.preventDefault();

          const fd = new FormData(form);
          const nombre = String(fd.get("nombre") || "").trim();
          const telefono = String(fd.get("telefono") || "").trim();
          const tipoProyecto = String(fd.get("tipoProyecto") || "").trim();
          const etapa = String(fd.get("etapa") || "").trim();
          const detalle = String(fd.get("detalle") || "").trim();

          if (!nombre || !telefono || !tipoProyecto || !etapa || !detalle) {
            form.reportValidity();
            return;
          }

          const payload = {
            nombre,
            telefono,
            tipoProyecto,
            etapa,
            detalle,
            source: "estudio.marmolesdeluxe.com",
            channel: "whatsapp",
            timestamp: new Date().toISOString(),
          };

          pushLeadEvent("studio_form_submit", {
            tipoProyecto,
            etapa,
          });

          if (webhookUrl) {
            fetch(webhookUrl, {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify(payload),
              keepalive: true,
            }).catch(() => {});
          }

          const text = `Deseo agendar un diagnóstico técnico con Studio Mármoles Deluxe. Nombre: ${nombre}. WhatsApp: ${telefono}. Proyecto: ${tipoProyecto}. Etapa: ${etapa}. Detalle: ${detalle}.`;
          window.location.href = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(text)}&utm_source=google_ads&utm_medium=cpc&utm_campaign=studio_marmoles_deluxe&utm_content=form_submit`;
        });
      }
    </script>
